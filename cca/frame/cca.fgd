            elif r == 34:
                base = "You are in a low chamber with dust deep on the floor. Each footfall raises a small cloud."
            elif r == 35:
                base = "You are in a sloping corridor. The walls curve smoothly toward a dim glimmer above."
            elif r == 36:
                base = "You are above a large room that drops away below to the south. A flat slab of stone juts out into the void."
            elif r == 37:
                base = "You are in a large low circular chamber whose floor is a slab of stone. Above, the rock-jumble continues."
            # --- Snake/dragon side passages, the two mazes, Witt's End ---
            # Canonical Crowther+Woods has the maze of twisty
            # passages all alike (8 rooms with identical text but
            # divergent exit logic in canon — we keep the text but
            # use a simple linear topology since making the maze
            # actually confusing requires a non-Euclidean room
            # mechanic that would be a sub-system of its own).
            elif r == 39:
                base = "You are in a small misty cavern. Walls and ceiling are slick with damp; water drips ceaselessly somewhere out of sight."
            elif r == 42:
                base = "You are in a dark, dirty alcove. Soot and dust lie thick on every surface, undisturbed for centuries."
            elif r == 43:
                base = "You are in a relatively wide spot in the passage. The east wall has bands of dark and light stone."
            elif r == 44:
                base = "You are in a secret canyon. The walls overhang above and meet to form a narrow ribbon of stars."
            elif r == 45:
                base = "The passage here is so tight you can barely squeeze through. There's a narrow opening to the east."
            elif r == 46:
                base = "You are in a tall east/west passage. The roof is lost in shadows above."
            elif r == 48:
                base = "You are in a boulder-strewn passage, with stones the size of small houses lying about."
            elif r == 49:
                base = "You are in a passage of polished limestone, smoothly weathered by ages of dripping water."
            # Maze of twisty little passages, all alike (50-57).
            # Each room shares the canonical text. Canonically the
            # maze is mapped by dropping items to mark visited
            # rooms. Our linear topology removes that puzzle but
            # preserves the iconic flavor.
            elif r >= 50 and r <= 57:
                base = "You are in a maze of twisty little passages, all alike."
            # Maze of twisty passages, all different (58-65). Same
            # iconic text, rearranged words to keep the player on
            # their toes.
            elif r == 58:
                base = "You are in a maze of twisty little passages, all different."
            elif r == 59:
                base = "You are in a maze of twisting little passages, all different."
            elif r == 60:
                base = "You are in a little maze of twisty passages, all different."
            elif r == 61:
                base = "You are in a twisting maze of little passages, all different."
            elif r == 62:
                base = "You are in a twisting little maze of passages, all different."
            elif r == 63:
                base = "You are in a twisty little maze of passages, all different."
            elif r == 64:
                base = "You are in a twisty maze of little passages, all different."
            elif r == 65:
                base = "You are in a little twisty maze of passages, all different."
            elif r == 66:
                base = "You are at one of the exits from the labyrinth, where a long passage stretches east."
            elif r == 67:
                base = "You are at Witt's End. Passages lead off in all directions but most are barely visible, and most of those that are visible appear to lead nowhere useful."
            elif r == 68:
                base = "You are at the bottom of a smoothly polished cone of limestone, with a steep climb back the way you came."
            # --- Phase E: Bedquilt extensions, reservoir, treasury,
            # cliff-and-ladder descent, post-cave outdoors, forest grid.
            elif r == 72:
                base = "You are in a long, sloping corridor that descends gently into the rock."
            elif r == 73:
                base = "You are in a sloping room above a large round chamber. The drop is sheer."
            elif r == 74:
                base = "You are in a large low room. Crawls lead north, southeast, and southwest."
            elif r == 75:
                base = "You are in a sloping corridor with a smooth ramp of stone underfoot."
            elif r == 76:
                base = "You are in the Soft Room. The walls are covered with a heavy curtain that muffles all sound."
            elif r == 77:
                base = "You are in a steep canyon. The walls overhang above you and meet to form a narrow ribbon of darkness."
            elif r == 78:
                base = "You are in a different secret canyon, twisting east-west. The walls bear faint runes."
            elif r == 79:
                base = "You are in a steep passage that descends sharply to the north."
            elif r == 80:
                base = "You are in a dirty passage. Soot stains the walls, and your feet leave clear tracks in the dust."
            elif r == 81:
                base = "You are in a wet room. Drip-formations cover the floor like inverted stalactites."
            elif r == 82:
                base = "You are in a different cobble crawl, low and twisty. The cobbles here glitter faintly with mica."
            elif r == 83:
                base = "You are at the edge of a vast underground reservoir. Black water laps quietly against a stone shelf."
            elif r == 84:
                base = "You are wading in a small underground stream. The water is icy-cold and crystal-clear."
            elif r == 85:
                base = "You are in front of a barren room, with the entrance arching low to the east."
            elif r == 86:
                base = "You are in a barren room, the floor and walls smooth and untouched."
            elif r == 87:
                base = "You are at the brink of a thirty-foot cliff. A passage continues to the east; below, a ledge runs along the cliff face."
            elif r == 89:
                base = "You are inside a cylindrical canyon. The walls rise smoothly to a band of grey light far above."
            elif r == 90:
                base = "You are in a smooth passage of polished stone, walls unbroken and ceiling low."
            elif r == 91:
                base = "You are in a different soft passage. Moss covers everything in a green carpet."
            elif r == 93:
                base = "You are on the south side of a different fissure, deeper and narrower than the first."
            elif r == 94:
                base = "You are in the Treasury. Glittering valuables line every shelf — long since looted, but the residue still sparkles."
            elif r == 96:
                base = "You are in a different forest, far to the north of the road. The trees here stand taller and darker."
            elif r == 97:
                base = "You are in a different forest, to the northeast."
            elif r == 98:
                base = "You are in a different forest, to the southeast."
            elif r == 99:
                base = "You are in a different forest, to the southwest."
            elif r == 100:
                base = "You are in a different forest, to the northwest."
            elif r == 108:
                base = "You are at a fork in the path. One branch leads east into shadow; the other curves back to the north."
            elif r == 115:
                base = "You are at the end of a long corridor. Far ahead, a faint glow promises an exit."
            elif r == 116:
                base = "You are in a pre-repository chamber, where the cave compels you onward but provides no path back."
            elif r == 119:
                base = "You are at a cliff face, with an iron ladder bolted into the rock leading down. Far below you can hear the faint murmur of water."
            elif r == 121:
                base = "You are at the bottom of the iron ladder, on a stone landing. Passages lead in several directions."
            elif r == 123:
                base = "You are in an anteroom carved with crude pictographs of strange beasts."
            elif r == 125:
                base = "You are in a small antechamber with niches set into each wall."
            # --- Phase F: iconic remainder ---
            elif r == 88:
                base = "You are in a decorated chamber whose walls are inlaid with strange carvings of dragons, beasts, and constellations."
            elif r == 92:
                base = "You are in a different soft passage. The floor is sand; your footfalls leave no echo."
            elif r == 95:
                base = "You are in a small chamber containing a battered vending machine with a hand-lettered sign: 'BATTERIES — 25 CENTS — IT WORKS NO REFUNDS'."
                if self.vending.is_loaded():
                    base = base + " A coin slot gleams faintly. (Try INSERT COINS.)"
                else:
                    base = base + " A second hand-lettered sign over the slot now reads: 'OUT OF BATTERIES'."
            elif r == 101:
                base = "You are in a different forest, far to the east. The trees are unfamiliar."
            elif r == 102:
                base = "You are in a different forest, far to the south. A small spring trickles between the roots of an ancient tree."
            elif r == 103:
                base = "You are in a different forest, far to the west. The light is greenish and the air close."
            elif r == 109:
                base = "You are in a low passage which curves westward. The ceiling is so low you must crawl."
            elif r == 113:
                base = "You are in a wide chamber with cracked walls. A dim light filters in from somewhere above."
            elif r == 122:
                base = "You are in an anteroom of polished basalt. Your footfalls ring sharply."
            elif r == 124:
                base = "You are in an anteroom carved from soft red stone. Faint torch-marks streak the walls."
            elif r == 126:
                base = "You are in an anteroom set deep in the rock, with a great fireplace cold and dark."
            # --- Final canon-completion rooms (Round 10) ---
            # Forest grid completion + inner anteroom cluster +
            # pre-Repository corridor branches. Brings the room
            # total up to ~140 (canon scope).
            elif r == 104:
                base = "You are in dense forest, the canopy thick enough to cast everything in green twilight."
            elif r == 105:
                base = "You are in scrub forest, with low brush snagging at your ankles. A faint path winds eastward."
            elif r == 106:
                base = "You are in a forest clearing. A small spring trickles up from beneath a flat slab of stone."
            elif r == 107:
                base = "You are in a path through the forest. Ferns brush your shoulders on either side."
            elif r == 110:
                base = "You are in a low passage with a curiously-shaped ceiling. The walls bear claw-marks."
            elif r == 111:
                base = "You are in a different secret canyon. A cool draft blows from somewhere ahead."
            elif r == 112:
                base = "You are in a tall canyon, narrow and impossibly high. Stars seem to glimmer in the rock above."
            elif r == 114:
                base = "You are in a crystal grotto. Walls and ceiling are studded with small clear crystals refracting your lamplight into hundreds of pinpoints."
            elif r == 127:
                base = "You are in an inner anteroom. Carved nameless figures stand sentinel along the walls."
            elif r == 128:
                base = "You are in a different inner anteroom, with a low arch leading deeper in."
            elif r == 129:
                base = "You are in a chamber whose floor is one polished slab of stone, smooth enough to reflect your lamp."
            elif r == 137:
                base = "You are in an antechamber outside the Repository. A solemn weight presses on you here."
            elif r == 138:
                base = "You are in a final corridor, the air still and cold. The Repository lies just ahead."
            elif r == 139:
                base = "You are in a small chamber adjoining the Repository. A single brass plaque on the wall reads 'EXIT'."
            elif r == 17:
                base = "You are at the edge of a deep, narrow fissure. The walls drop away to nothing far below."
                if self.crystal_bridge.is_built():
                    base = base + " A glittering crystal bridge spans the fissure."
            elif r == 69:
                base = "You are in a hall of mirrors on the far side of the fissure. Cool air drifts in from somewhere unseen."
            # NPC presence overlays.
            if r == self.bird.get_location() and self.bird.get_state() == "free":
                base = base + " A small bird flutters nearby."
            if r == self.SNAKE_ROOM and self.snake.is_blocking():
                base = base + " A huge green snake bars further passage."
            if r == self.BEAR_HOME_ROOM:
                var bs: String = self.bear.get_state()
                if bs == "hungry":
                    base = base + " A large bear is chained to the wall, glaring hungrily."
                elif bs == "tame":
                    base = base + " A friendly-looking bear sits chained, its tongue lolling."
            if r == self.TROLL_ROOM and self.troll.is_blocking_bridge():
                base = base + " A burly troll stands guard at the bridge, demanding tribute."
            if r == self.DRAGON_ROOM and self.dragon.is_alive():
                base = base + " A huge green dragon dozes on a Persian rug."
            # Treasure overlays — for each treasure, if it's
            # in this room (not carried) mention it. The rug
            # is special: covered by dragon while alive.
            if self.gold.get_location() == r and self.gold.get_state() == "in_room":
                base = base + " There's a gleam of gold here."
            if self.silver.get_location() == r and self.silver.get_state() == "in_room":
                base = base + " A pile of silver bars catches your eye."
            if self.diamonds.get_location() == r and self.diamonds.get_state() == "in_room":
                base = base + " Diamonds glitter in the dark."
            if self.jewelry.get_location() == r and self.jewelry.get_state() == "in_room":
                base = base + " Fine jewelry lies scattered."
            if self.pearl.get_location() == r and self.pearl.get_state() == "in_room":
                base = base + " A pearl as big as your fist rests here."
            if self.vase.get_location() == r and self.vase.get_state() == "in_room":
                base = base + " A delicate Ming vase rests on a pedestal."
            if self.eggs.get_location() == r and self.eggs.get_state() == "in_room":
                base = base + " A nest of golden eggs sits in the corner."
            if self.trident.get_location() == r and self.trident.get_state() == "in_room":
                base = base + " A jewel-encrusted trident leans against the wall."
            if self.emerald.get_location() == r and self.emerald.get_state() == "in_room":
                base = base + " An enormous emerald sparkles brilliantly."
            if self.spices.get_location() == r and self.spices.get_state() == "in_room":
                base = base + " Rare spices fill the air with their scent."
            if self.chest.get_location() == r and self.chest.get_state() == "in_room":
                base = base + " A treasure chest, half-hidden, catches your eye."
            if self.pyramid.get_location() == r and self.pyramid.get_state() == "in_room":
                base = base + " A miniature pyramid of solid gold rests here."
            if self.rug.get_location() == r and self.rug.get_state() == "in_room" and not self.dragon.is_alive():
                base = base + " A magnificent Persian rug lies on the floor."
            if self.coins.get_location() == r and self.coins.get_state() == "in_room":
                base = base + " A pile of rare coins glints here."
            if self.statuette.get_location() == r and self.statuette.get_state() == "in_room":
                base = base + " A delicate jade statuette rests in the corner."
            # Rod overlay — not a treasure (no point value), but
            # visible in its room when not carried, same as the
            # treasures above.
            if not self.rod_carried and self.rod_location == r:
                base = base + " A small black rod with a rusty star at one end lies on the ground."
            if not self.keys_carried and self.keys_location == r:
                base = base + " A set of brass keys lies on the floor."
            if not self.bottle_carried and self.bottle_location == r:
                if self.bottle.has_water():
                    base = base + " A small glass bottle, full of water, sits on a wooden shelf."
                else:
                    base = base + " A small empty glass bottle sits on a wooden shelf."
            # Grate state overlay — only at the depression itself.
            if r == self.GRATE_ROOM:
                if self.grate.is_locked():
                    base = base + " The grate is locked."
                else:
                    base = base + " The grate is unlocked and swung open."
            return base
        }

        _verb_take(noun: String): String {
            # Special-case the bird and chain because both
            # have cross-FSM consequences (Bird transitions on
            # capture; Bear transitions on take_chain — and
            # transitions to $Attacking if the bear is still
            # $Hungry, which Adventure surfaces as a death-
            # adjacent message).
            if noun == "bird":
                if self.bird.get_state() != "free":
                    return "There is no bird here."
                if self.player.get_room() != self.bird.get_location():
                    return "There is no bird here."
                self.bird.capture()
                self.player.take(self.BIRD_ID)
                return "You catch the bird in your hand."
            if noun == "rod":
                if self.rod_carried:
                    return "You already have the rod."
                if self.player.get_room() != self.rod_location:
                    return "There is no rod here."
                self.rod_carried = true
                self.player.take(self.ROD_ID)
                return "Taken."
            if noun == "keys" or noun == "key":
                if self.keys_carried:
                    return "You already have the keys."
                if self.player.get_room() != self.keys_location:
                    return "There are no keys here."
                self.keys_carried = true
                self.player.take(self.KEYS_ID)
                return "Taken."
            if noun == "bottle":
                if self.bottle_carried:
                    return "You already have the bottle."
                if self.player.get_room() != self.bottle_location:
                    return "There is no bottle here."
                self.bottle_carried = true
                self.player.take(self.BOTTLE_ID)
                return "Taken."
            if noun == "chain":
                if self.player.get_room() != self.BEAR_HOME_ROOM:
                    return "There is no chain here."
                var bs: String = self.bear.get_state()
                if bs == "hungry":
                    # Cross-FSM: the bear becomes $Attacking
                    # AND the player dies. Adventure brokers
                    # both transitions; the driver detects the
                    # death state on the next post-command
                    # check and surfaces the resurrection prompt.
                    self.bear.take_chain()
                    self.player.die()
                    return "With a roar the bear lunges at you. You should have fed it first. You have been killed."
                elif bs == "tame":
                    self.bear.take_chain()
                    self.player.take(self.CHAIN_ID)
                    return "The bear lumbers along behind you on its chain."
                return "The chain has already been taken."
            # Treasures
            return self._take_treasure_by_name(noun)
        }

        _verb_drop(noun: String): String {
            # Drop is non-special for most items — the bird
            # gets its own `release` verb because the outcome
            # depends on the room. The chain is the cross-FSM
            # case here: dropping the chain releases the bear
            # in the current room, and Adventure brokers the
            # bear→troll consequence chain.
            if noun == "rod":
                if not self.rod_carried:
                    return "You aren't carrying the rod."
                self.rod_carried = false
                self.rod_location = self.player.get_room()
                self.player.drop(self.ROD_ID)
                return "Dropped."
            if noun == "keys" or noun == "key":
                if not self.keys_carried:
                    return "You aren't carrying the keys."
                self.keys_carried = false
                self.keys_location = self.player.get_room()
                self.player.drop(self.KEYS_ID)
                return "Dropped."
            if noun == "bottle":
                if not self.bottle_carried:
                    return "You aren't carrying the bottle."
                self.bottle_carried = false
                self.bottle_location = self.player.get_room()
                self.player.drop(self.BOTTLE_ID)
                return "Dropped."
            if noun == "chain":
                if self.bear.get_state() != "following":
                    return "You aren't holding the bear's chain."
                self.bear.drop_chain()
                self.player.drop(self.CHAIN_ID)
                var room: int = self.player.get_room()
                if room == self.TROLL_ROOM and self.troll.is_blocking_bridge():
                    self.troll.scared_off()
                    return "The bear lumbers up to the troll. The troll, taken aback, flees over the bridge with a shriek."
                return "The bear settles down at your side, glaring."
            # Treasures
            return self._drop_treasure_by_name(noun)
        }

        _take_treasure_by_name(name: String): String {
            var room: int = self.player.get_room()
            if name == "gold":
                if self.gold.try_take(room):
                    self.player.take(self.GOLD_ID)
                    return "Taken."
                return "There is no gold here."
            elif name == "silver":
                if self.silver.try_take(room):
                    self.player.take(self.SILVER_ID)
                    return "Taken."
                return "There is no silver here."
            elif name == "diamonds":
                if self.diamonds.try_take(room):
                    self.player.take(self.DIAMONDS_ID)
                    return "Taken."
                return "There are no diamonds here."
            elif name == "jewelry":
                if self.jewelry.try_take(room):
                    self.player.take(self.JEWELRY_ID)
                    return "Taken."
                return "There is no jewelry here."
            elif name == "pearl":
                if self.pearl.try_take(room):
                    self.player.take(self.PEARL_ID)
                    return "Taken."
                return "There is no pearl here."
            elif name == "vase":
                if self.vase.try_take(room):
                    self.player.take(self.VASE_ID)
                    return "Taken. (handle with care.)"
                return "There is no vase here."
            elif name == "eggs":
                if self.eggs.try_take(room):
                    self.player.take(self.EGGS_ID)
                    return "Taken."
                return "There are no eggs here."
            elif name == "trident":
                if self.trident.try_take(room):
                    self.player.take(self.TRIDENT_ID)
                    return "Taken."
                return "There is no trident here."
            elif name == "emerald":
                if self.emerald.try_take(room):
                    self.player.take(self.EMERALD_ID)
                    return "Taken."
                return "There is no emerald here."
            elif name == "spices":
                if self.spices.try_take(room):
                    self.player.take(self.SPICES_ID)
                    return "Taken."
                return "There are no spices here."
            elif name == "chest":
                if self.chest.try_take(room):
                    self.player.take(self.CHEST_ID)
                    return "Taken."
                return "There is no chest here."
            elif name == "pyramid":
                if self.pyramid.try_take(room):
                    self.player.take(self.PYRAMID_ID)
                    return "Taken."
                return "There is no pyramid here."
            elif name == "rug":
                # The rug is under the dragon. Only takeable
                # after the dragon is dead. Cross-FSM gate.
                if self.dragon.is_alive() and room == self.DRAGON_ROOM:
                    return "The dragon is sleeping on the rug. You'd best deal with it first."
                if self.rug.try_take(room):
                    self.player.take(self.RUG_ID)
                    return "Taken. The Persian rug is exquisite."
                return "There is no rug here."
            elif name == "coins":
                if self.coins.try_take(room):
                    self.player.take(self.COINS_ID)
                    return "Taken."
                return "There are no coins here."
            elif name == "statuette":
                if self.statuette.try_take(room):
                    self.player.take(self.STATUETTE_ID)
                    return "Taken."
                return "There is no statuette here."
            return "I don't see that here."
        }

        _drop_treasure_by_name(name: String): String {
            var room: int = self.player.get_room()
            var outcome: String = ""
            var item_id: int = -1
            var value: int = 0
            if name == "gold":
                outcome = self.gold.try_drop(room)
                item_id = self.GOLD_ID
                value = self.gold.get_value()
            elif name == "silver":
                outcome = self.silver.try_drop(room)
                item_id = self.SILVER_ID
                value = self.silver.get_value()
            elif name == "diamonds":
                outcome = self.diamonds.try_drop(room)
                item_id = self.DIAMONDS_ID
                value = self.diamonds.get_value()
            elif name == "jewelry":
                outcome = self.jewelry.try_drop(room)
                item_id = self.JEWELRY_ID
                value = self.jewelry.get_value()
            elif name == "pearl":
                outcome = self.pearl.try_drop(room)
                item_id = self.PEARL_ID
                value = self.pearl.get_value()
            elif name == "vase":
                outcome = self.vase.try_drop(room)
                item_id = self.VASE_ID
                value = self.vase.get_value()
            elif name == "eggs":
                outcome = self.eggs.try_drop(room)
                item_id = self.EGGS_ID
                value = self.eggs.get_value()
            elif name == "trident":
                outcome = self.trident.try_drop(room)
                item_id = self.TRIDENT_ID
                value = self.trident.get_value()
            elif name == "emerald":
                outcome = self.emerald.try_drop(room)
                item_id = self.EMERALD_ID
                value = self.emerald.get_value()
            elif name == "spices":
                outcome = self.spices.try_drop(room)
                item_id = self.SPICES_ID
                value = self.spices.get_value()
            elif name == "chest":
                outcome = self.chest.try_drop(room)
                item_id = self.CHEST_ID
                value = self.chest.get_value()
            elif name == "pyramid":
                outcome = self.pyramid.try_drop(room)
                item_id = self.PYRAMID_ID
                value = self.pyramid.get_value()
            elif name == "rug":
                outcome = self.rug.try_drop(room)
                item_id = self.RUG_ID
                value = self.rug.get_value()
            elif name == "coins":
                outcome = self.coins.try_drop(room)
                item_id = self.COINS_ID
                value = self.coins.get_value()
            elif name == "statuette":
                outcome = self.statuette.try_drop(room)
                item_id = self.STATUETTE_ID
                value = self.statuette.get_value()
            else:
                return "You aren't carrying that."

            if outcome == "not carried":
                return "You aren't carrying " + name + "."
            if outcome == "already deposited":
                return "That treasure is already deposited."
            self.player.drop(item_id)
            if outcome == "deposited":
                # Cross-FSM: deposit drives the endgame timer.
                # Also award the treasure's value to the score
                # breakdown (each treasure has a value that's
                # baked into its parameter at construction).
                self.endgame.treasure_deposited()
                self.score_treasures = self.score_treasures + value
                self.real_score = self.real_score + value
                return "Safely stowed in the well house. A fine treasure indeed!"
            return "Dropped."
        }

        _verb_feed(noun: String): String {
            if noun != "bear":
                return "I don't know how to feed that."
            if self.player.get_room() != self.BEAR_HOME_ROOM:
                return "There is no bear here."
            if self.bear.get_state() != "hungry":
                return "The bear isn't interested."
            self.bear.feed()
            return "The bear eats the food eagerly and looks much friendlier."
        }

        _verb_attack(noun: String): String {
            if noun != "dragon":
                return "Don't be ridiculous."
            if self.player.get_room() != self.DRAGON_ROOM:
                return "There is nothing here to attack."
            if not self.dragon.is_alive():
                return "The dragon is already dead."
            self.dragon.attack()
            return "With what? Your bare hands?"
        }

        _verb_yes(): String {
            # Yes/no only meaningful when something is asking.
            # The Dragon's $Asked is the canonical case; if
            # other interactive prompts are added, route here.
            if self.dragon.is_awaiting_confirmation():
                self.dragon.yes()
                return "Congratulations! You have just vanquished a dragon with your bare hands."
            return "I don't understand."
        }

        _verb_no(): String {
            if self.dragon.is_awaiting_confirmation():
                self.dragon.no()
                return "The dragon, sensing your hesitation, lets you back away."
            return "I don't understand."
        }

        _verb_examine(noun: String): String {
            # Object/feature inspection. Shorter than LOOK
            # (which describes the whole room); EXAMINE
            # describes one item or feature in detail.
            if noun == "lamp":
                if self.lamp.is_lit():
                    return "Your brass lantern is currently lit. Battery: " + str(self.lamp.battery_left()) + " turns."
                return "Your brass lantern is dark. Battery: " + str(self.lamp.battery_left()) + " turns."
            elif noun == "bird":
                if self.player.carrying(self.BIRD_ID):
                    return "A small bird flutters in your hand."
                return "A small bird flutters about, chirping."
            elif noun == "snake":
                if self.snake.is_blocking():
                    return "A huge green snake, fierce and terrible-looking. It bars the way east."
                return "There is no snake here anymore."
            elif noun == "dragon":
                if self.dragon.is_alive():
                    return "A huge green dragon dozes on a Persian rug, its scales catching what little light there is."
                return "The dragon is dead. Its corpse lies sprawled on the rug."
            elif noun == "bear":
                var bs: String = self.bear.get_state()
                if bs == "hungry":
                    return "A large brown bear, looking very hungry. It is chained to the wall."
                elif bs == "tame":
                    return "A friendly-looking bear, contentedly chewing."
                elif bs == "following":
                    return "The bear pads along behind you, held by its chain."
                elif bs == "released":
                    return "The bear is settled here, glaring around."
                return "There is no bear here."
            elif noun == "troll":
                if self.troll.is_blocking_bridge():
                    return "A burly troll, demanding tribute to cross his bridge."
                return "The troll is gone."
            elif noun == "sign":
                if self.player.get_room() == 33:    # Y2 (canonical)
                    return "The sign reads: 'Y2'."
                return "There is no sign here."
            return "You see nothing special about that."
        }

        _verb_read(noun: String): String {
            # READ is mostly for signs and inscriptions. We
            # share examine's text for objects with writing.
            if noun == "sign":
                if self.player.get_room() == 33:    # Y2 (canonical)
                    return "The sign reads: 'Y2'."
                return "There is no sign here."
            elif noun == "keys" or noun == "bottle":
                return "Nothing is written on it."
            return "There is nothing to read here."
        }

        _verb_chant(word: String): String {
            # Drive the EggsIncantation FSM; observe whether
            # the chant just completed (transition into $Idle
            # from $WaitingFoo on "foo") and dispatch the
            # eggs.reappear side effect cross-FSM.
            var was_waiting_foo: bool = (self.eggs_chant.get_state() == "waiting_foo")
            var reply: String = self.eggs_chant.say(word)
            if was_waiting_foo and word == "foo":
                # The eggs return to the Giant Room. If they
                # were already deposited, this resets them
                # (player can re-deposit and double-score —
                # canon bug, we replicate intentionally).
                self.eggs.reappear(28)    # canonical: Giant Room
                return reply + " The nest of golden eggs has appeared elsewhere!"
            return reply
        }

        _verb_throw(noun: String): String {
            # THROW is mostly for axes at dwarves. Routes to
            # the same attack-dwarf-in-room logic the dispatch
            # interface exposes; it just reads more naturally.
            if noun == "axe":
                return self._attack_dwarf_in_current()
            return "I don't know how to throw that."
        }

        _verb_wave(noun: String): String {
            # The rod is the only wave-able object. The bridge
            # only materializes when waved AT the fissure; waving
            # the rod anywhere else gets a flavored deflection so
            # the player knows the rod has a use without giving
            # the puzzle away outright.
            if noun != "rod":
                return "Waving that around won't do much."
            if not self.rod_carried:
                return "You don't have the rod."
            var r: int = self.player.get_room()
            if r != self.FISSURE_ROOM:
                return "You wave the rod, feeling slightly silly. Nothing happens."
            return self.crystal_bridge.wave()
        }

        _verb_unlock(noun: String): String {
            # The grate is the only canonical lockable in this
            # port. UNLOCK and OPEN both route here. We require the
            # player to be at the depression (room 8) AND carrying
            # the keys; the Grate FSM does the actual transition.
            if noun != "grate" and noun != "":
                return "I don't see how to unlock that."
            if self.player.get_room() != self.GRATE_ROOM:
                return "There is nothing here to unlock."
            return self.grate.unlock(self.keys_carried)
        }

        _verb_lock(noun: String): String {
            if noun != "grate" and noun != "":
                return "I don't see how to lock that."
            if self.player.get_room() != self.GRATE_ROOM:
                return "There is nothing here to lock."
            return self.grate.lock()
        }

        _verb_insert(noun: String): String {
            # Insert coins into the vending machine. Cross-FSM
            # choreography: VendingMachine handles its own state
            # transition; Adventure removes the coins from the
            # player and refreshes the lamp on success.
            if noun != "coins" and noun != "coin":
                return "You can't insert that."
            if self.player.get_room() != self.VENDING_ROOM:
                return "There's nothing here to insert into."
            # Defer to the vending FSM. We snapshot the
            # before-state so we can detect a successful
            # transition vs an already-empty machine. The FSM's
            # message itself is canonical for both branches.
            var was_loaded: bool = self.vending.is_loaded()
            var carrying_coins: bool = self.player.carrying(self.COINS_ID)
            var msg: String = self.vending.insert(carrying_coins)
            if was_loaded and carrying_coins and not self.vending.is_loaded():
                # Successful trade. Consume the coins (drop from
                # inventory and relocate to room 0 — out of
                # bounds, no overlay, not deposited) and refresh
                # the lamp.
                self.player.drop(self.COINS_ID)
                self.coins.reappear(0)
                self.lamp.refresh()
            return msg
        }

        # World inspection: is the player's current room a water
        # source? Canon CCA's water sources are the well house
        # spring (3), the valley stream (4), the underground
        # reservoir (83), and the underground stream (84).
        _at_water_source(): bool {
            var r: int = self.player.get_room()
            if r == 3 or r == 4 or r == 83 or r == 84:
                return true
            return false
        }

        _verb_fill(noun: String): String {
            if noun != "bottle":
                return "You can't fill that."
            if not self.bottle_carried:
                return "You don't have the bottle."
            return self.bottle.fill(self._at_water_source())
        }

        _verb_pour(noun: String): String {
            # POUR with no noun, or POUR WATER, or POUR BOTTLE —
            # all pour the bottle's contents at the player's
            # location. Special case: at the West Pit (room 23)
            # the water is absorbed by the plant, growing it.
            # Anywhere else it just spills.
            if noun != "" and noun != "bottle" and noun != "water":
                return "You can't pour that."
            if not self.bottle_carried:
                return "You don't have the bottle."
            if not self.bottle.has_water():
                return "The bottle is empty."
            var r: int = self.player.get_room()
            # Empty the bottle regardless of where the water lands.
            var msg: String = self.bottle.pour()
            if r == self.WEST_PIT_ROOM:
                # Cross-FSM: water the plant.
                var grow_msg: String = self.plant.water()
                return "The water soaks into the soil. " + grow_msg
            return msg
        }

        _verb_water(noun: String): String {
            # WATER PLANT is the canonical CCA verb. We accept
            # bare WATER (defaults to the plant if at West Pit)
            # and "water plant" / "water beanstalk" / "water it".
            if noun != "" and noun != "plant" and noun != "beanstalk" and noun != "it":
                return "You can't water that."
            if self.player.get_room() != self.WEST_PIT_ROOM:
                return "There's nothing here that needs watering."
            # Same effect as POUR at the West Pit — defer to
            # _verb_pour to keep the choreography in one place.
            return self._verb_pour("water")
        }

        _verb_drink(noun: String): String {
            # Bare DRINK or DRINK WATER drinks the bottle
            # contents. Drinking from a stream / reservoir works
            # too as a flavor response.
            if noun != "" and noun != "water" and noun != "bottle":
                return "You can't drink that."
            if not self.bottle_carried:
                if self._at_water_source():
                    return "The water is wonderfully fresh and clear, but you have no way to carry any."
                return "You have nothing to drink."
            return self.bottle.drink()
        }

        _attack_dwarf_in_current(): String {
            # Inline copy of attack_dwarf_in_room's logic so
            # the verb handler can call it as an action. We
            # keep both shapes (interface + action) for the
            # two callsites — the test harness uses the
            # interface, the verb dispatcher uses this action.
            var r: int = self.player.get_room()
            if self.dwarf1.get_state() == "stalking" and self.dwarf1.get_room() == r:
                self.dwarf1.attack()
                if self.dwarf1.get_state() == "dead":
                    return "Your axe finds its mark. The dwarf collapses."
                return "Your axe misses the dwarf, who cackles."
            elif self.dwarf2.get_state() == "stalking" and self.dwarf2.get_room() == r:
                self.dwarf2.attack()
                if self.dwarf2.get_state() == "dead":
                    return "Your axe finds its mark. The dwarf collapses."
                return "Your axe misses the dwarf, who cackles."
            elif self.dwarf3.get_state() == "stalking" and self.dwarf3.get_room() == r:
                self.dwarf3.attack()
                if self.dwarf3.get_state() == "dead":
                    return "Your axe finds its mark. The dwarf collapses."
                return "Your axe misses the dwarf, who cackles."
            elif self.dwarf4.get_state() == "stalking" and self.dwarf4.get_room() == r:
                self.dwarf4.attack()
                if self.dwarf4.get_state() == "dead":
                    return "Your axe finds its mark. The dwarf collapses."
                return "Your axe misses the dwarf, who cackles."
            elif self.dwarf5.get_state() == "stalking" and self.dwarf5.get_room() == r:
                self.dwarf5.attack()
                if self.dwarf5.get_state() == "dead":
                    return "Your axe finds its mark. The dwarf collapses."
                return "Your axe misses the dwarf, who cackles."
            return "There's no dwarf to throw an axe at here."
        }

        _verb_release(noun: String): String {
            # The bird-shaped corner of the verb table. Coordinates
            # the cross-FSM consequence: when the bird's release
            # transition lands at $Released (i.e., the player was
            # in the snake's room), notify the Snake too.
            if noun != "bird":
                return "I don't know how to release that."
            if not self.player.carrying(self.BIRD_ID):
                return "You aren't carrying the bird."
            var room: int = self.player.get_room()
            self.bird.release(room)
            self.player.drop(self.BIRD_ID)
            # Cross-FSM coordination. Bird's own state change is
            # complete; we now reach across to Snake/Dragon and
            # let them react.
            var bs: String = self.bird.get_state()
            if bs == "released" and self.snake.is_blocking():
                self.snake.bird_released_here()
                return "The little bird attacks the green snake furiously, and the snake slithers off in fear."
            elif bs == "dead":
                return "The dragon catches the little bird in midair and swallows it whole."
            return "The bird flies off into the gloom."
        }

        _verb_move(noun: String): String {
            # If MagicWordTeleport already transformed our event,
            # noun will be a string room ID like "2" or "4".
            # Otherwise fall back to the toggle behavior so
            # bare "move" still does something during testing.
            var dest: int = noun.to_int()
            # Pre-move guard: the canon Plover Room (100) is fatal
            # to the bird. Canonical CCA: the magic of the Plover
            # Room is *destructive* to small animals — the bird
            # vanishes entirely (no corpse, no recovery), the
            # player still completes the move and arrives at
            # Plover alone.
            var plover_bird_msg: String = ""
            if dest == 100 and self.player.carrying(self.BIRD_ID):
                self.bird.vanish()
                self.player.drop(self.BIRD_ID)
                plover_bird_msg = "As you start to chant, the magic of the Plover Room flares around the little bird in your hand. There is a brief, brilliant flash, and the bird is gone. "
            if dest > 0:
                self.player.move_to(dest)
            else:
                var r: int = self.player.get_room()
                # toggle between end-of-road (1) and well house (3)
                self.player.move_to(3 if r == 1 else 1)
            var nr: int = self.player.get_room()
            if self._room_is_dark(nr) and not self.lamp.is_lit():
                return plover_bird_msg + "You move into darkness."
            return plover_bird_msg + "You are " + self._verb_look().substr(7)  # strip "You are"
        }

        # World inspection: is the player's current room dark?
        # Canonical CCA tags each room with a flag; we use the
        # canonical surface-rooms-are-lit rule: rooms 1-8 (end
        # of road, hill, well house, valley, forests, slit,
        # depression) plus the Plover Room (canon 100, lit by an
        # otherworldly glow) are lit. Everything else — the
        # cave proper, starting at the chamber below the grate
        # (room 9) — is dark when the lamp is off.
        _room_is_dark(room: int): bool {
            if room >= 1 and room <= 8:
                return false
            if room == 100:
                return false
            return not self.lamp.is_lit()
        }

    domain:
        # Composition. Order doesn't matter for @@[persist]
        # auto-traversal but reading top-to-bottom helps a
        # reader follow the world.
        bus = @@AspectBus()
        lamp = @@Lamp()
        player = @@Player()
        darkness = @@DarknessGate()
        backpack = @@BackpackLimit()
        magic = @@MagicWordTeleport()
        score_ledger = @@ScoreLedger()
        bird = @@Bird()
        snake = @@Snake()
        bear = @@Bear()
        troll = @@Troll()

        # Five dwarves, each with a distinct seed so their
        # probabilistic axe-throw outcomes diverge. The seed
        # is a constructor parameter on the Dwarf system; this
        # is the parameterized-system-with-multiple-instances
        # pattern (chapter 5's ghosts, chapter 8's guards).
        dwarf1 = @@Dwarf(1)
        dwarf2 = @@Dwarf(2)
        dwarf3 = @@Dwarf(3)
        dwarf4 = @@Dwarf(4)
        dwarf5 = @@Dwarf(5)

        # Endgame phase machine — multi-stage HSM with timer.
        # The genuine multi-state showpiece in CCA.
        endgame = @@Endgame()

        # Three hints, all parameterized off the same Hint
        # system but with the threshold parameter. The player
        # has to be in the trigger condition for `threshold`
        # consecutive turns before the hint becomes available.
        bird_hint = @@Hint(3)
        dark_hint = @@Hint(3)
        snake_hint = @@Hint(3)

        # Dragon — small but iconic. Multi-turn parser dialog
        # encoded as state. The "ATTACK / WITH WHAT? / YES"
        # sequence stays consistent across turns because
        # $Asked is a real state.
        dragon = @@Dragon()

        # Pirate — probabilistic encounter once player is
        # carrying multiple treasures.
        pirate = @@Pirate(99)

        # Eggs incantation — 4-state sequence parser. Said
        # anywhere; on completion, summons the eggs back to
        # their home room (14, the Giant Room).
        eggs_chant = @@EggsIncantation()

        # Crystal bridge across the fissure — two-state FSM that
        # the player toggles by waving the rod at the fissure.
        # Cross-FSM choreography lives in Adventure._verb_wave;
        # the bridge itself only knows its own toggle.
        crystal_bridge = @@CrystalBridge()

        # Steel grate at the depression (room 8) into the chamber
        # below (room 9). Starts $Locked; the keys live in the
        # well house. Same orchestrator pattern as the rod-and-
        # bridge: each subsystem owns its slice, Adventure brokers
        # the cross-cuts.
        grate = @@Grate()

        # The Vending Machine in room 95 — canon's pre-endgame
        # Easter egg. Trade rare coins for fresh lamp batteries
        # (and lose the points the coins would score at the well
        # house — that's the puzzle decision).
        vending = @@VendingMachine()

        # Bottle (item) and Plant (FSM in West Pit). Canonical
        # CCA's beanstalk puzzle: take bottle from well house,
        # fill at a water source, pour on the plant in West Pit,
        # climb. Two waterings to grow it from $Tiny → $Tall →
        # $Huge so you can climb all the way to room 25.
        bottle = @@Bottle()
        plant  = @@Plant()

        # Five treasures, each in its home room with a value.
        # Real CCA has 15; we model the canonical lifecycle on
        # this subset to keep the maze manageable. Adding more
        # is mechanical (one named instance + one branch in
        # _take_treasure_by_name + _drop_treasure_by_name +
        # treasures_deposited / total_score).
        # Canonical CCA: per-treasure value cap is 14 (2 points
        # for first take + 12 for deposit at well house). Sum
        # across 15 treasures = 210 points of treasure score —
        # the dominant component of the canonical 350-point
        # target. Earlier port values (5/10/15) under-scored.
        gold      = @@Treasure(11, 14)   # debris room
        silver    = @@Treasure(33, 14)   # Y2 marker
        diamonds  = @@Treasure(71, 14)   # scorched cavern (with dragon, rug)
        jewelry   = @@Treasure(118,14)   # cliff with ledge (beyond troll bridge)
        pearl     = @@Treasure(100,14)   # Plover Room canon 100 (only via PLOVER magic)
        vase      = @@Treasure(38, 14, true)   # Oriental Room — fragile!
        eggs      = @@Treasure(28, 14)   # Giant Room
        # Treasures whose canonical home rooms aren't yet
        # placed in the port topology — temporarily housed in
        # the 130-139 interpolated zone pending Phase 5
        # canonical-room placement.
        trident   = @@Treasure(130,14)   # Sapphire Hallway (interpolated)
        emerald   = @@Treasure(131,14)   # Vast Hall (interpolated)
        spices    = @@Treasure(40, 14)   # Alcove
        chest     = @@Treasure(132,14)   # Pirate's chest cavern (interpolated)
        pyramid   = @@Treasure(133,14)   # Pyramid Chamber (interpolated)
        rug       = @@Treasure(71, 14)   # under dragon (drops once dragon dies)
        coins     = @@Treasure(134,14)   # Coin Niche (interpolated)
        statuette = @@Treasure(135,14)   # Sloping Passage (interpolated)

        # World-layout constants. Must match Bird's domain
        # SNAKE_ROOM / DRAGON_ROOM to keep cross-system logic
        # consistent. (The Bird's release transitions reference
        # its own copies; the Adventure's _verb_release uses
        # its copies for snake-notification routing.)
        BIRD_ID: int = 100
        CHAIN_ID: int = 101
        GOLD_ID: int = 110
        SILVER_ID: int = 111
        DIAMONDS_ID: int = 112
        JEWELRY_ID: int = 113
        PEARL_ID: int = 114
        VASE_ID: int = 115
        EGGS_ID: int = 116
        TRIDENT_ID: int = 117
        EMERALD_ID: int = 118
        SPICES_ID: int = 119
        CHEST_ID: int = 120
        PYRAMID_ID: int = 121
        RUG_ID: int = 122
        COINS_ID: int = 123
        STATUETTE_ID: int = 124
        # Canonical Crowther/Woods 1977 room numbering. Where a
        # room name has a canonical analog, we use that number;
        # interpolated rooms (treasure-side-rooms not in canon)
        # take numbers in the 130-139 gap zone above the canon
        # repository (140) so they don't collide.
        BIRD_HOME_ROOM: int = 13      # bird chamber
        SNAKE_ROOM: int = 47          # secret east-west canyon
        DRAGON_ROOM: int = 71         # scorched cavern
        BEAR_HOME_ROOM: int = 70      # bear chamber
        TROLL_ROOM: int = 117         # troll bridge
        CHEST_ROOM: int = 132         # pirate's chest cavern (interpolated)
        DEPOSIT_ROOM: int = 3         # well house — must match Treasure.DEPOSIT_ROOM
        # Fissure / rod-puzzle rooms. The rod starts in the
        # debris room (its canonical CCA home) and can be carried
        # to the fissure to summon the crystal bridge.
        FISSURE_ROOM: int = 17        # east of fissure
        GRATE_ROOM: int = 8           # depression with the steel grate
        KEYS_HOME_ROOM: int = 3       # well house
        VENDING_ROOM: int = 95        # vending machine room
        WEST_PIT_ROOM: int = 23       # plant lives here
        BOTTLE_ID: int = 132
        BOTTLE_HOME_ROOM: int = 3     # well house
        ROD_HOME_ROOM: int = 11       # debris room — same as gold
        ROD_ID: int = 130
        KEYS_ID: int = 131

        # The rod's runtime state. Carried as a domain bool +
        # location int rather than a full FSM, because the rod
        # has no behavior of its own — it's a key-with-no-lock.
        # The bridge it summons is a separate FSM (crystal_bridge).
        rod_carried: bool = false
        rod_location: int = 11    # debris room (matches ROD_HOME_ROOM)
        keys_carried: bool = false
        keys_location: int = 3    # well house (matches KEYS_HOME_ROOM)
        bottle_carried: bool = false
        bottle_location: int = 3  # well house (matches BOTTLE_HOME_ROOM)

        # Tick counter (advances every tick(), not every
        # do_command). Some commands are free; others tick.
        # For now, tick() is called once per do_command via
        # the driver.
        turns: int = 0

        # Scoring — running totals. Each component is
        # incremented at the right transition (deposit,
        # first-visit, hint, endgame), never decremented
        # except hint_penalty which goes negative. real_score
        # is the rolled-up total returned by score().
        real_score: int = 0
        score_treasures: int = 0
        score_visits: int = 0
        score_hints: int = 0
        score_endgame: int = 0
        rooms_visited: Array = []
        # Latched dwarf-attack flag — set by _maybe_dwarf_attack
        # when a dwarf hits and read+cleared via dwarf_threw_axe().
        # Domain bool so @@[persist] round-trips it across saves.
        dwarf_axe_flag: bool = false
}
