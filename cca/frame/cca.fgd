# ============================================================
# Colossal Cave Adventure — Frame source
# ============================================================
# This is the real-CCA compilation unit. It will grow as
# systems land. The toy aspect-bus demo lives in a separate
# file (aspects.fgd) — that's the smoke-test fixture, not the
# game.
#
# Frame doesn't have an import mechanism, so a single .fgd
# must contain every system that composes with another. CCA's
# Adventure orchestrator composes the AspectBus, Lamp, and
# eventually all the NPC/object/aspect systems. They all live
# here.
#
# Currently in this file:
#
#   AspectBus  — priority-ordered interceptor registry. Same
#                shape as in aspects.fgd; duplicated here
#                because of the no-imports constraint. If
#                Frame gains a `@@import` directive later,
#                consolidate.
#
#   Lamp       — the canonical CCA object. Battery counter,
#                dim-warning threshold, dark-room-makes-game-
#                impossible interaction. Real HSM with
#                sub-states.
#
#   Adventure  — top-level orchestrator. Currently just holds
#                the bus and the lamp; will accumulate the
#                world as we go.
#
# Build with:
#   framec compile frame/cca.fgd --language gdscript -o generated/
# ============================================================

@@[target("gdscript")]


# ------------------------------------------------------------
# AspectBus
# ------------------------------------------------------------
# Same definition as aspects.fgd's bus. See that file's
# header comment for the design rationale (priority-ordered
# listener metadata, $Idle/$Dispatching states for queue-
# during-dispatch, why we hold names not @@system refs).
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system AspectBus : RefCounted {

    interface:
        register(name: String, priority: int)
        unregister(name: String)
        is_registered(name: String): bool
        begin_dispatch()
        end_dispatch()
        ordered_names(): Array

    machine:

        $Idle {
            register(name: String, priority: int) {
                self._add_or_replace(name, priority)
            }
            unregister(name: String) {
                self._remove(name)
            }
            begin_dispatch() {
                -> $Dispatching
            }
            end_dispatch() {}
            is_registered(name: String): bool { @@:(self._has(name)) }
            ordered_names(): Array            { @@:(self._names_sorted()) }
        }

        $Dispatching {
            register(name: String, priority: int) {
                self.pending_register.append({
                    "name": name,
                    "priority": priority,
                })
            }
            unregister(name: String) {
                self.pending_unregister.append(name)
            }
            begin_dispatch() {}
            end_dispatch() {
                self._apply_pending()
                -> $Idle
            }
            is_registered(name: String): bool { @@:(self._has(name)) }
            ordered_names(): Array            { @@:(self._names_sorted()) }
        }

    actions:

        _add_or_replace(name: String, priority: int) {
            var i: int = 0
            while i < self.listeners.size():
                if self.listeners[i].name == name:
                    self.listeners[i].priority = priority
                    return
                i = i + 1
            self.listeners.append({"name": name, "priority": priority})
        }

        _remove(name: String) {
            var i: int = 0
            while i < self.listeners.size():
                if self.listeners[i].name == name:
                    self.listeners.remove_at(i)
                    return
                i = i + 1
        }

        _has(name: String): bool {
            var i: int = 0
            while i < self.listeners.size():
                if self.listeners[i].name == name:
                    return true
                i = i + 1
            return false
        }

        _names_sorted(): Array {
            var pairs: Array = []
            var i: int = 0
            while i < self.listeners.size():
                pairs.append([self.listeners[i].priority, self.listeners[i].name])
                i = i + 1
            pairs.sort_custom(func(a, b): return a[0] > b[0])
            var names: Array = []
            i = 0
            while i < pairs.size():
                names.append(pairs[i][1])
                i = i + 1
            return names
        }

        _apply_pending() {
            var i: int = 0
            while i < self.pending_unregister.size():
                self._remove(self.pending_unregister[i])
                i = i + 1
            self.pending_unregister = []
            i = 0
            while i < self.pending_register.size():
                var p: Dictionary = self.pending_register[i]
                self._add_or_replace(p.name, p.priority)
                i = i + 1
            self.pending_register = []
        }

    domain:
        listeners: Array = []
        pending_register: Array = []
        pending_unregister: Array = []
}


# ------------------------------------------------------------
# Lamp
# ------------------------------------------------------------
# The canonical CCA object FSM. Crowther's lamp had a finite
# battery; players who wandered too long ran out and got
# stuck in the dark. This is the same behavior modeled as
# states.
#
# State diagram:
#
#   $Off                          # default; no battery drain
#     │ light()
#     v
#   $On                           # HSM parent — drains battery
#     ├── $On.$Bright              # >= dim_threshold turns left
#     ├── $On.$Dim                 # < dim_threshold; warning printed
#     └── $On.$Out                 # 0 turns left; effectively off
#                                    (extinguish() returns to $Off
#                                    only after a fresh-batteries
#                                    install — modeled as a
#                                    refresh() event).
#
#   $Off ←─ extinguish() / refresh()
#
# tick() drains the battery once per turn while $On. The
# threshold transitions ($Bright → $Dim, $Dim → $Out) fire from
# inside tick() when battery crosses the boundary.
#
# Why HSM rather than parallel sub-states:
#   $On's children share the "decrement battery" behavior;
#   the only differences are the messages printed and whether
#   the lamp actually emits light. Putting the decrement in
#   the parent's tick handler and overriding queries
#   (is_lit, message) in children is what HSM's parent
#   inheritance gives you for free.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Lamp : RefCounted {

    interface:
        # Lifecycle
        light()                    # $Off → $On.$Bright (or $Out if drained)
        extinguish()               # $On.* → $Off
        refresh()                  # $Out → fully recharged $Off (then light)

        # Per-turn
        tick()                     # called once per command turn

        # Queries
        get_state(): String        # "off" | "bright" | "dim" | "out"
        is_lit(): bool             # actually emitting useful light
        battery_left(): int        # turns remaining before $Out
        last_message(): String     # warning printed this tick, or ""

    machine:

        # ------------------------------------------------------------
        # $Off — default. tick() does nothing (no battery drain).
        # The lamp can be lit unless the battery is at zero, in
        # which case light() routes directly to $On.$Out (so the
        # player gets the "lamp is dead" feedback rather than a
        # silently broken light).
        # ------------------------------------------------------------
        $Off {
            light() {
                if self.battery <= 0:
                    -> $Out
                else:
                    -> $Bright
            }

            tick() {}

            refresh() {
                self.battery = self.MAX_BATTERY
            }

            get_state(): String   { @@:("off") }
            is_lit(): bool        { @@:(false) }
            battery_left(): int   { @@:(self.battery) }
            last_message(): String { @@:("") }
        }

        # ------------------------------------------------------------
        # $On — HSM parent. Defines the per-tick battery drain
        # and the threshold-crossing transitions. Children
        # ($Bright, $Dim, $Out) inherit tick(); they just
        # override queries.
        # ------------------------------------------------------------
        $On {
            extinguish() {
                self.last_warning = ""
                -> $Off
            }

            tick() {
                # Drain one charge per turn. Transitions are
                # threshold-driven: as battery crosses
                # dim_threshold we go $Bright → $Dim, and as it
                # hits zero we go $Dim → $Out.
                if self.battery > 0:
                    self.battery = self.battery - 1
                # Defer to children for the actual transition
                # via _check_threshold — we don't transition
                # from the parent because we don't know which
                # child we're in. Children call _check_threshold
                # at the end of their own tick handlers.
            }

            # Default refresh: top up battery, drop to $Bright.
            # Children may override (e.g., $Out adds a clear-
            # warning + transition into $Bright).
            refresh() {
                self.battery = self.MAX_BATTERY
                self.last_warning = ""
                -> $Bright
            }

            get_state(): String    { @@:("on") }
            is_lit(): bool         { @@:(true) }
            battery_left(): int    { @@:(self.battery) }
            last_message(): String { @@:(self.last_warning) }
        }

        # ------------------------------------------------------------
        # $Bright — full-strength light. Transitions to $Dim
        # when battery drops below the dim threshold.
        # ------------------------------------------------------------
        $Bright => $On {
            tick() {
                # Inherit parent's decrement logic via $^, then
                # check our own threshold. (Frame's $^ on tick
                # routes the event upward; the parent decrements
                # battery, then control returns here for the
                # post-decrement check.)
                self.last_warning = ""
                if self.battery > 0:
                    self.battery = self.battery - 1
                if self.battery <= 0:
                    -> $Out
                elif self.battery <= self.DIM_THRESHOLD:
                    # Canon msg #183 verbatim.
                    self.last_warning = "Your lamp is getting dim. You'd best start wrapping this up, unless you can find some fresh batteries. I seem to recall there's a vending machine in the maze. Bring some coins with you."
                    -> $Dim
            }

            get_state(): String { @@:("bright") }
            => $^
        }

        # ------------------------------------------------------------
        # $Dim — battery low. Same drain rate; warning is
        # surfaced once on entry (not every tick) by clearing
        # last_warning each tick after the first. Transitions
        # to $Out at zero.
        # ------------------------------------------------------------
        $Dim => $On {
            $>() {
                # Surface the dim warning once on entry so the
                # driver can pick it up. Canon msg #183 verbatim.
                self.last_warning = "Your lamp is getting dim. You'd best start wrapping this up, unless you can find some fresh batteries. I seem to recall there's a vending machine in the maze. Bring some coins with you."
            }

            tick() {
                # Clear warning after one tick so it doesn't
                # repeat every turn. The driver reads
                # last_message() each turn; an empty string
                # means "nothing to print."
                self.last_warning = ""
                if self.battery > 0:
                    self.battery = self.battery - 1
                if self.battery <= 0:
                    -> $Out
            }

            get_state(): String { @@:("dim") }
            => $^
        }

        # ------------------------------------------------------------
        # $Out — battery depleted. Lamp is on but emitting no
        # light (mechanically, this gates dark-room navigation).
        # extinguish() returns to $Off; refresh() puts a new
        # battery in and re-routes through $Off.light(). The
        # driver typically prompts the player to extinguish or
        # refresh on entry.
        # ------------------------------------------------------------
        $Out => $On {
            $>() {
                # Canon msg #184 verbatim.
                self.last_warning = "Your lamp has run out of power."
            }

            tick() {
                self.last_warning = ""
                # No drain; we're already at zero.
            }

            refresh() {
                self.battery = self.MAX_BATTERY
                self.last_warning = ""
                -> $Bright
            }

            is_lit(): bool      { @@:(false) }   # override parent
            get_state(): String { @@:("out") }
            => $^
        }

    domain:
        # Tunables. The original CCA had a 330-turn battery
        # with a dim warning around turn 300 (last 30 turns).
        # We use the same shape but keep the names parametric
        # so they can be tweaked per-game-balance without
        # changing logic.
        MAX_BATTERY: int = 330
        DIM_THRESHOLD: int = 30

        # Mutable state.
        battery: int = 330
        last_warning: String = ""
}


# ------------------------------------------------------------
# Player
# ------------------------------------------------------------
# Tracks where the player is, what they're carrying, and how
# many times they've died. CCA gives the player three free
# resurrections (death numbers 1, 2, 3 are recoverable; the
# fourth is permanent). The state machine encodes this:
#
#   $Alive  ── die()    ─► $Dead    (after 1st, 2nd, 3rd death)
#                          revive() ─► $Alive
#           ── die()    ─► $Permadead  (4th and beyond)
#
# Inventory and room are domain variables — they belong to the
# player regardless of mode. Death drops everything (canon
# CCA behavior); $Dead.revive() re-enters $Alive at the cave
# entrance with empty inventory.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Player : RefCounted {

    interface:
        move_to(room_id: int)
        die()
        revive()

        # Inventory
        take(item_id: int)
        drop(item_id: int)
        carrying(item_id: int): bool
        inventory_size(): int

        # Queries
        get_state(): String
        get_room(): int
        get_deaths(): int

    machine:

        # ------------------------------------------------------------
        # $Alive — the normal mode. move_to / take / drop all
        # mutate domain. die() advances the death counter and
        # routes to $Dead or $Permadead based on whether we
        # still have free resurrections.
        # ------------------------------------------------------------
        $Alive {
            move_to(room_id: int) {
                self.room = room_id
            }

            take(item_id: int) {
                if not self.inventory.has(item_id):
                    self.inventory.append(item_id)
            }

            drop(item_id: int) {
                self.inventory.erase(item_id)
            }

            die() {
                self.deaths = self.deaths + 1
                if self.deaths > self.MAX_RESURRECTIONS:
                    -> $Permadead
                else:
                    -> $Dead
            }

            carrying(item_id: int): bool { @@:(self.inventory.has(item_id)) }
            inventory_size(): int        { @@:(self.inventory.size()) }
            get_state(): String          { @@:("alive") }
            get_room(): int              { @@:(self.room) }
            get_deaths(): int            { @@:(self.deaths) }
        }

        # ------------------------------------------------------------
        # $Dead — recoverable. revive() resets to the cave
        # entrance with empty inventory and goes back to $Alive.
        # The driver/orchestrator decides when to call revive
        # (in real CCA this is gated by a "OK?" prompt).
        # ------------------------------------------------------------
        $Dead {
            revive() {
                self.room = self.START_ROOM
                self.inventory = []
                -> $Alive
            }

            carrying(item_id: int): bool { @@:(false) }
            inventory_size(): int        { @@:(0) }
            get_state(): String          { @@:("dead") }
            get_room(): int              { @@:(self.room) }
            get_deaths(): int            { @@:(self.deaths) }
        }

        # ------------------------------------------------------------
        # $Permadead — terminal. The 4th death.
        # ------------------------------------------------------------
        $Permadead {
            carrying(item_id: int): bool { @@:(false) }
            inventory_size(): int        { @@:(0) }
            get_state(): String          { @@:("permadead") }
            get_room(): int              { @@:(self.room) }
            get_deaths(): int            { @@:(self.deaths) }
        }

    domain:
        room: int = 1                  # canonical: end-of-road
        inventory: Array = []
        deaths: int = 0
        START_ROOM: int = 1            # canonical: end-of-road
        MAX_RESURRECTIONS: int = 3
}


# ------------------------------------------------------------
# DarknessGate (aspect)
# ------------------------------------------------------------
# The first real CCA aspect. Sits on the bus and intercepts
# informational verbs ("look", "examine") when the player is
# in a dark room and the lamp isn't providing light. Returns a
# "consume" verdict with a "It is pitch dark." message; the
# orchestrator picks up the message text from the verdict
# event payload.
#
# Why this is an aspect, not a check inside the base handler:
# the same condition gates many verbs ("look" today, plus
# "examine X", "read X", "search X" later). Putting the gate
# in each verb's handler is the flag-on-the-base-machine smell.
# The aspect intercepts at the dispatch boundary, in front of
# all of them.
#
# What about MOVE in the dark? Real CCA allows movement in
# dark rooms — you might fall into a pit. So MOVE doesn't
# belong to this aspect; that risk is handled elsewhere.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system DarknessGate : RefCounted {

    interface:
        try_handle(event: Dictionary): Dictionary

    machine:

        $Active {
            try_handle(event: Dictionary): Dictionary {
                # Read world facts from the event payload — the
                # orchestrator built it with the relevant
                # snapshot. The aspect doesn't reach into the
                # world directly; that keeps it testable.
                var dark: bool = event.get("is_dark", false)
                var verb: String = event.get("verb", "")
                if dark and verb == "read":
                    # Canon msg #151 — READ in dark gets a snarkier
                    # rebuff than the generic look-into-darkness.
                    self.consumed_count = self.consumed_count + 1
                    @@:return({
                        "verdict": "consume",
                        "event": event,
                        "message": "What's the matter, can't you read? Now you'd best start over.",
                    })
                if dark and (verb == "look" or verb == "examine"):
                    # Canon msg #16.
                    self.consumed_count = self.consumed_count + 1
                    @@:return({
                        "verdict": "consume",
                        "event": event,
                        "message": "It is pitch dark. You can't see a thing.",
                    })
                @@:({"verdict": "pass", "event": event})
            }
        }

    domain:
        # Counter for tests / future telemetry. Not strictly
        # needed but makes the aspect's behavior observable
        # without reading dispatch logs.
        consumed_count: int = 0
}


# ------------------------------------------------------------
# BackpackLimit (aspect)
# ------------------------------------------------------------
# Consumes "take" verbs when the player is already carrying
# `LIMIT` items. Returns the canonical CCA "you can't carry
# that many things" message.
#
# Why this is an aspect, not a check inside the take handler:
# the limit is a cross-cutting policy that applies *before*
# any item-specific logic. Putting it in the take handler
# means every take-related verb ("take", "get", "pickup",
# "grab" once we accept synonyms) duplicates the check.
# The aspect intercepts at the boundary instead.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system BackpackLimit : RefCounted {

    interface:
        try_handle(event: Dictionary): Dictionary

    machine:

        $Active {
            try_handle(event: Dictionary): Dictionary {
                var verb: String = event.get("verb", "")
                var carrying: int = event.get("carrying_count", 0)
                if verb == "take" and carrying >= self.LIMIT:
                    self.consumed_count = self.consumed_count + 1
                    @@:return({
                        "verdict": "consume",
                        "event": event,
                        "message": "You can't carry anything more. You'll have to drop something first.",
                    })
                @@:({"verdict": "pass", "event": event})
            }
        }

    domain:
        LIMIT: int = 7              # canonical CCA carry limit
        consumed_count: int = 0
}


# ------------------------------------------------------------
# MagicWordTeleport (aspect)
# ------------------------------------------------------------
# Transforms the magic-word verbs (XYZZY, PLUGH, PLOVER) into
# "move" commands with the appropriate destination room when
# the player is in a recognized source room. In a wrong
# location, the word passes through to the base handler,
# which returns "Nothing happens."
#
# This is the canonical "transform" verdict in action: the
# event leaves the aspect with a different `verb` and `noun`,
# and downstream aspects + the base handler see the
# transformed event.
#
# Why this is an aspect, not first-class verb dispatch:
# magic words are *cross-cutting* — they're not part of the
# normal verb grammar (TAKE/DROP/LOOK/etc.). Adding them as
# regular verbs would require the base handler to know the
# room-pair table, which is exactly the cross-cutting concern
# we extracted. Aspects own this kind of input rewriting.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system MagicWordTeleport : RefCounted {

    interface:
        try_handle(event: Dictionary): Dictionary

    machine:

        $Active {
            try_handle(event: Dictionary): Dictionary {
                var verb: String = event.get("verb", "")
                var room: int = event.get("room", -1)

                # XYZZY: pairs well house (3) ↔ debris room (11).
                # Per Don Woods 1977: travel-table rows
                #   "3 11 62" / "11 3 62"  (motion 62 = XYZZY).
                if verb == "xyzzy":
                    if room == 3:
                        @@:return(self._teleport(event, 11))
                    elif room == 11:
                        @@:return(self._teleport(event, 3))

                # PLUGH: pairs well house (3) ↔ Y2 (33).
                # Canon travel-table: "3 33 65" / "33 3 65".
                if verb == "plugh":
                    if room == 3:
                        @@:return(self._teleport(event, 33))
                    elif room == 33:
                        @@:return(self._teleport(event, 3))

                # PLOVER: pairs Y2 (33) ↔ Plover Room (canon 100).
                # Canon travel-table: "33 100 71" / "100 33 71".
                if verb == "plover":
                    if room == 33:
                        @@:return(self._teleport(event, 100))
                    elif room == 100:
                        @@:return(self._teleport(event, 33))

                # Unrecognized or wrong-room: pass through.
                # Base handler returns "Nothing happens."
                @@:({"verdict": "pass", "event": event})
            }
        }

    actions:

        # Builds the transformed event: verb becomes "move" and
        # the noun becomes the destination room as a string
        # (the base handler's _verb_move parses it). Bumps the
        # internal counter for observability.
        _teleport(event: Dictionary, dest_room: int): Dictionary {
            self.transforms_count = self.transforms_count + 1
            var transformed: Dictionary = event.duplicate()
            transformed["verb"] = "move"
            transformed["noun"] = str(dest_room)
            transformed["magic_dest"] = dest_room
            return {
                "verdict": "transform",
                "event": transformed,
            }
        }

    domain:
        transforms_count: int = 0
}


# ------------------------------------------------------------
# Bird
# ------------------------------------------------------------
# The canonical CCA bird. Lives in its starting room until
# captured by the player, accompanies the player while caged,
# and on release behaves differently depending on the room:
#
#   $Free → $Caged                via capture()
#   $Caged → $Released            release at SNAKE_ROOM
#   $Caged → $Dead                release at DRAGON_ROOM
#   $Caged → $Free (somewhere)    release anywhere else
#
# The bird's location is tracked as a domain variable. While
# $Caged, location is sentinel -1 (with the player); the
# Adventure correlates that with the player's current room
# when needed. After $Released or $Free-after-release, the
# bird is wherever it was let go.
#
# Cross-FSM interaction with Snake is coordinated by the
# Adventure orchestrator: when release() lands the bird in
# $Released and the player was in the snake's room, the
# Adventure tells the Snake. The Bird itself doesn't know
# about the Snake — it just records "I was released at
# room N." This keeps the systems independently testable.
#
# Why hardcoded SNAKE_ROOM / DRAGON_ROOM in the Bird's domain
# rather than parameterizing: Frame supports `@@system Foo(p:int)`
# parameters, but for two integer constants that map to the
# fixed CCA geography, a domain default + a comment noting the
# constant must match Adventure's is the simpler shape. If the
# room layout ever becomes data-driven we'll parameterize.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Bird : RefCounted {

    interface:
        capture()
        release(at_room: int)
        # Canonical CCA: the Plover Room's magic is fatal to
        # the bird. Adventure calls vanish() when the player
        # tries to enter Plover while carrying the bird, and
        # the bird transitions to $Dead with no corpse left.
        vanish()

        get_state(): String
        get_location(): int      # current room, or -1 if carried/dead

    machine:

        $Free {
            capture() {
                self.location_room = -1
                -> $Caged
            }
            get_state(): String  { @@:("free") }
            get_location(): int  { @@:(self.location_room) }
        }

        $Caged {
            release(at_room: int) {
                self.location_room = at_room
                if at_room == self.SNAKE_ROOM:
                    -> $Released
                elif at_room == self.DRAGON_ROOM:
                    -> $Dead
                else:
                    -> $Free
            }
            vanish() {
                self.location_room = -1
                -> $Dead
            }
            get_state(): String  { @@:("caged") }
            get_location(): int  { @@:(-1) }
        }

        $Released {
            # Terminal: the bird drove off the snake and flew
            # away. Could re-enter $Free with a different
            # location later, but classic CCA leaves it gone.
            get_state(): String  { @@:("released") }
            get_location(): int  { @@:(self.location_room) }
        }

        $Dead {
            # Terminal: the dragon ate the bird, or the Plover
            # Room's magic destroyed it. No corpse, no recovery.
            get_state(): String  { @@:("dead") }
            get_location(): int  { @@:(-1) }
        }

    domain:
        # Starting position — bird-chamber room. Must match
        # Adventure.BIRD_HOME_ROOM.
        location_room: int = 13

        # Special rooms that change release outcomes. Must
        # match Adventure.SNAKE_ROOM and Adventure.DRAGON_ROOM.
        SNAKE_ROOM: int = 19         # Hall of Mountain King — canon 19
        DRAGON_ROOM: int = 119       # Secret canyon (dragon) — canon 119
}


# ------------------------------------------------------------
# Snake
# ------------------------------------------------------------
# Two-state NPC. Initial $Blocking; the bird-released-at-
# snake-room event drives the transition to $Gone, opening
# the east passage out of the Hall of Mists.
#
# This is the smallest meaningful FSM in CCA. Almost a single
# bit. Modeling it as a state machine rather than a boolean
# pays off only because every system in this file ends up
# composed under the same persistence + dispatch envelope —
# being a state machine makes Snake a first-class citizen
# alongside Bird and Bear.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Snake : RefCounted {

    interface:
        bird_released_here()
        get_state(): String
        is_blocking(): bool

    machine:

        $Blocking {
            bird_released_here() {
                -> $Gone
            }
            get_state(): String   { @@:("blocking") }
            is_blocking(): bool   { @@:(true) }
        }

        $Gone {
            get_state(): String   { @@:("gone") }
            is_blocking(): bool   { @@:(false) }
        }
}


# ------------------------------------------------------------
# Bear
# ------------------------------------------------------------
# CCA's most behavior-rich NPC. The bear has five states; the
# transitions form a near-linear progression interrupted by
# one branching hazard.
#
# State diagram:
#
#   $Hungry  ── feed() ─►  $Tame
#       │
#       └── take_chain() ─►  $Attacking   (player took chain
#                                          without feeding —
#                                          bear is hostile)
#
#   $Tame    ── take_chain() ─►  $Following
#   $Following ── drop_chain() ─►  $Released
#
#   $Attacking and $Released are terminal: Adventure inspects
#   bear.get_state() each turn and triggers consequences
#   (player.die() on $Attacking; troll-scaring on $Released
#   in the troll's room — hooked up when Troll lands).
#
# Why no HSM parent for $Tame/$Following/$Released:
#   They share `is_friendly() = true` but defining a
#   $Friendly parent would buy us 3 lines saved at the cost
#   of explaining the hierarchy. With only one shared query,
#   flat states read more directly.
#
# Cross-FSM coordination:
#   Adventure observes bear.get_state() each turn.
#   - $Attacking: adventure calls player.die() and resets
#     bear to $Hungry (in real CCA the bear gives up after
#     killing once — game over for the player either way).
#   - $Released in the troll's room: adventure tells the
#     Troll, transitioning Troll → $Vanished.
#
# Same orchestration shape as Bird/Snake. The bear doesn't
# know about the troll; Adventure brokers.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Bear : RefCounted {

    interface:
        feed()
        take_chain()
        drop_chain()
        get_state(): String
        is_friendly(): bool
        is_dangerous(): bool

    machine:

        # ------------------------------------------------------------
        # $Hungry — initial. Bear is on its chain, looking at
        # the player as a snack. Feeding it transitions to
        # $Tame; trying to take the chain without feeding first
        # is a bad day for the player.
        # ------------------------------------------------------------
        $Hungry {
            feed() {
                -> $Tame
            }
            take_chain() {
                -> $Attacking
            }
            get_state(): String   { @@:("hungry") }
            is_friendly(): bool   { @@:(false) }
            is_dangerous(): bool  { @@:(true) }
        }

        # ------------------------------------------------------------
        # $Tame — fed, no longer hostile. Still chained.
        # take_chain() now safely transitions to $Following.
        # ------------------------------------------------------------
        $Tame {
            take_chain() {
                -> $Following
            }
            get_state(): String   { @@:("tame") }
            is_friendly(): bool   { @@:(true) }
            is_dangerous(): bool  { @@:(false) }
        }

        # ------------------------------------------------------------
        # $Following — player holds the chain; bear walks
        # alongside. Drop the chain to release the bear in
        # whatever room you're in.
        # ------------------------------------------------------------
        $Following {
            drop_chain() {
                -> $Released
            }
            get_state(): String   { @@:("following") }
            is_friendly(): bool   { @@:(true) }
            is_dangerous(): bool  { @@:(false) }
        }

        # ------------------------------------------------------------
        # $Released — terminal. The bear stays put, friendly
        # but not following. Used to scare the troll off the
        # bridge when released in the troll's room.
        # ------------------------------------------------------------
        $Released {
            get_state(): String   { @@:("released") }
            is_friendly(): bool   { @@:(true) }
            is_dangerous(): bool  { @@:(false) }
        }

        # ------------------------------------------------------------
        # $Attacking — terminal-ish. The Adventure detects this
        # state on the next turn boundary and triggers
        # player.die(). Real CCA can't recover from this so we
        # treat it as a dead-end here too.
        # ------------------------------------------------------------
        $Attacking {
            get_state(): String   { @@:("attacking") }
            is_friendly(): bool   { @@:(false) }
            is_dangerous(): bool  { @@:(true) }
        }
}


# ------------------------------------------------------------
# Troll
# ------------------------------------------------------------
# Stands at the troll bridge demanding tribute. Three states:
#
#   $Demanding ── pay_toll() ──► $TollPaid
#              ── scared_off() ─► $Vanished
#
# The bear connection is the canonical CCA payoff: release a
# friendly bear in the troll's room and the troll flees. The
# Adventure orchestrates that — Troll itself doesn't know the
# Bear exists, just like Snake doesn't know about the Bird.
#
# is_blocking_bridge() is what callers use to decide whether
# the east passage out of the troll's room is open. Both
# $TollPaid and $Vanished open the bridge; the difference is
# whether the player forfeited a treasure to do it.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Troll : RefCounted {

    interface:
        pay_toll()
        scared_off()
        get_state(): String
        is_blocking_bridge(): bool

    machine:

        $Demanding {
            pay_toll()    { -> $TollPaid }
            scared_off()  { -> $Vanished }
            get_state(): String         { @@:("demanding") }
            is_blocking_bridge(): bool  { @@:(true) }
        }

        $TollPaid {
            get_state(): String         { @@:("toll_paid") }
            is_blocking_bridge(): bool  { @@:(false) }
        }

        $Vanished {
            get_state(): String         { @@:("vanished") }
            is_blocking_bridge(): bool  { @@:(false) }
        }
}


# ------------------------------------------------------------
# Dwarf (parameterized × 5)
# ------------------------------------------------------------
# Five identical instances composed under different seeds so
# their probabilistic outcomes (axe-throw rolls, eventually
# axe-hit-back rolls) diverge predictably. This is the
# parameterized-systems-with-multiple-instances pattern that
# Pac-Man's ghosts and Stealth's guards demonstrated; CCA's
# dwarves are the third application of it in this repo.
#
# State diagram (per dwarf):
#
#   $Hidden ── wake_up(room) ──► $Stalking
#   $Stalking ── attack() ──► $Dead    (probabilistic, 70%
#                                       chance per attempt;
#                                       seed makes it
#                                       reproducible across
#                                       save/restore)
#   $Stalking ── flee() ──► $Hidden    (rare; in real CCA the
#                                       dwarves vanish into
#                                       the gloom occasionally)
#
# Why 5 instances rather than an Array of dwarves: framec
# auto-traverses *named* domain fields (`dwarf1`, `dwarf2`, …)
# for @@[persist], not generic Array<@@system>. Same constraint
# that drove AspectBus to hold name strings instead of system
# references. With named fields, the persistence story is
# automatic; the trade-off is a small if-ladder in Adventure
# to dispatch attacks to whichever dwarf is in the player's
# current room.
#
# Determinism: probabilistic outcomes use a per-dwarf seed +
# step counter. Same seed, same number of attacks → same
# outcomes. Save/restore round-trips the seed and step, so
# replay from a saved point is byte-identical.
#
# Determinism: probabilistic outcomes use a per-dwarf seed +
# step counter. Same seed, same number of attacks → same
# outcomes. Save/restore round-trips the seed and step, so
# replay from a saved point is byte-identical.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Dwarf(seed: int) : RefCounted {

    interface:
        wake_up(at_room: int)
        attack()                   # player attacks dwarf — may kill
        try_throw_axe(anger: int): bool  # dwarf attacks player — hit pct ramps with anger
        flee()                     # dwarf disengages
        get_state(): String
        get_room(): int
        get_seed(): int
        get_step(): int
        get_attack_step(): int

    machine:

        $Hidden {
            wake_up(at_room: int) {
                self.room = at_room
                -> $Stalking
            }
            try_throw_axe(anger: int): bool {
                @@:(false)             # not yet on the field
            }
            get_state(): String      { @@:("hidden") }
            get_room(): int          { @@:(-1) }
            get_seed(): int          { @@:(self.seed) }
            get_step(): int          { @@:(self.step) }
            get_attack_step(): int   { @@:(self.attack_step) }
        }

        $Stalking {
            attack() {
                # Roll a deterministic pseudo-random in [0,100).
                # Seeded by (seed, step) so replays from a saved
                # game produce identical outcomes. 70% kill rate
                # matches roughly canonical CCA odds.
                self.step = self.step + 1
                var x: int = self.seed * 1664525 + self.step * 1013904223
                x = ((x >> 16) ^ x) * 22695477
                x = x & 0xffffffff
                var roll: int = x % 100
                if roll < 70:
                    -> $Dead
            }
            try_throw_axe(anger: int): bool {
                # Dwarf throws an axe at the player. Separate
                # PRNG counter from the player-attacks-dwarf
                # rolls so the two streams don't interfere.
                #
                # Canon advent.for STMT 6090ish: hit rate is
                #     95 * (DFLAG - 2) / 1000
                # where DFLAG=2 is first combat (always misses),
                # DFLAG=3..N ramp the hit pct as the dwarves
                # grow angrier (FEED dwarf bumps DFLAG, in canon
                # SETTING the hit rate floor higher each time).
                # DFLAG=2 → 0% (always miss); DFLAG=10 → 76%.
                # Anger floor is 2 (post-first-combat); guard
                # against negative ramps for callers that pass
                # dwarf_anger before it's been bumped past 2.
                self.attack_step = self.attack_step + 1
                var x: int = self.seed * 22695477 + self.attack_step * 1664525
                x = ((x >> 16) ^ x) * 1013904223
                x = x & 0xffffffff
                var roll: int = x % 100
                var hit_pct: int = 0
                if anger > 2:
                    hit_pct = 95 * (anger - 2) / 10
                @@:(roll < hit_pct)
            }
            flee() {
                -> $Hidden
            }
            get_state(): String      { @@:("stalking") }
            get_room(): int          { @@:(self.room) }
            get_seed(): int          { @@:(self.seed) }
            get_step(): int          { @@:(self.step) }
            get_attack_step(): int   { @@:(self.attack_step) }
        }

        $Dead {
            # Terminal. The player's axe-throw connected.
            try_throw_axe(anger: int): bool {
                @@:(false)
            }
            get_state(): String      { @@:("dead") }
            get_room(): int          { @@:(-1) }
            get_seed(): int          { @@:(self.seed) }
            get_step(): int          { @@:(self.step) }
            get_attack_step(): int   { @@:(self.attack_step) }
        }

    domain:
        seed: int = seed
        room: int = -1
        step: int = 0
        attack_step: int = 0
}


# ------------------------------------------------------------
# Endgame
# ------------------------------------------------------------
# The multi-stage closing sequence. CCA's most genuinely
# multi-state piece of game logic, and the place where
# Frame's state-machine semantics earn the most keep in this
# project: timers, threshold-driven transitions, and a
# terminal puzzle state that the rest of the world has to
# defer to once it's reached.
#
# State diagram:
#
#   $Active                         (normal play)
#       │ treasure_deposited() — fires when the count
#       │   crosses TREASURES_TO_TRIGGER
#       v
#   $Closing                        (cave is closing)
#       │ $>() seeds closing_timer
#       │ tick() decrements; warnings emitted at thresholds
#       │ closing_timer hits 0
#       v
#   $InRepository                   (player teleported here
#       │                            with all treasures + a
#       │                            stick of dynamite — the
#       │                            "marker")
#       │ detonate() (called when the player drops the
#       │   marker and detonates it from the right place)
#       v
#   $Won                            (terminal)
#
# This is genuinely multi-stage: each transition has its own
# entry condition, its own timer or guard, and its own set of
# valid events. Try expressing this as a flag-on-a-class
# pattern and you'll feel why state machines exist.
#
# Cross-FSM:
#   Adventure observes endgame.is_closing(), endgame.in_repository(),
#   endgame.is_won() to decide which world rules apply this
#   turn. During $Closing, normal movement still works but the
#   driver appends a "the cave is closing" warning to look()
#   output. During $InRepository, normal movement is replaced
#   with the puzzle subset (drop marker, detonate). On $Won,
#   the game ends.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Endgame : RefCounted {

    interface:
        # Driver tells endgame each time a treasure was
        # successfully deposited. We trigger on the threshold
        # crossing.
        treasure_deposited()

        # Per-turn tick. Decrements the closing timer when in
        # $Closing.
        tick()

        # Trigger the explosion in the repository. Drives
        # $InRepository → $Won.
        detonate()

        # Canon panic (advent.for STMT 2): when the player tries
        # to leave the cave during $Closing, msg #130 fires and
        # CLOCK2 is capped at 15. Subsequent attempts don't
        # re-cap (PANIC latch). No-op outside $Closing.
        panic()

        # Queries for the orchestrator
        get_state(): String
        is_closing(): bool
        in_repository(): bool
        is_won(): bool
        is_panicked(): bool
        treasures_count(): int
        closing_timer(): float

    machine:

        # ------------------------------------------------------------
        # $Active — normal play. treasure_deposited() counts up
        # toward the trigger threshold; on crossing, transition
        # to $Closing.
        # ------------------------------------------------------------
        $Active {
            treasure_deposited() {
                self.treasures = self.treasures + 1
                if self.treasures >= self.TREASURES_TO_TRIGGER:
                    -> $Closing
            }
            tick() {
                # No-op. Timers are state-local.
            }
            detonate() {
                # No-op outside the repository.
            }
            panic() {
                # No-op — panic only meaningful in $Closing.
            }
            get_state(): String         { @@:("active") }
            is_closing(): bool          { @@:(false) }
            in_repository(): bool       { @@:(false) }
            is_won(): bool              { @@:(false) }
            is_panicked(): bool         { @@:(false) }
            treasures_count(): int      { @@:(self.treasures) }
            closing_timer(): float      { @@:(0.0) }
        }

        # ------------------------------------------------------------
        # $Closing — the cave is closing. State-variable timer
        # ticks down; warning messages get emitted at thresholds
        # (driver picks them up via closing_timer() and decides
        # what to print).
        # ------------------------------------------------------------
        $Closing {
            $.timer: float = 0.0
            $.panicked: bool = false

            $>() {
                $.timer = self.CLOSING_DURATION
            }

            treasure_deposited() {
                # Still counts (for final score) but doesn't
                # re-trigger anything.
                self.treasures = self.treasures + 1
            }

            tick() {
                $.timer = $.timer - 1.0
                if $.timer <= 0.0:
                    -> $InRepository
            }

            detonate() {
                # No-op until in repository.
            }

            panic() {
                # Canon advent.for STMT 2: first attempt to leave
                # the cave during $Closing caps CLOCK2 at 15
                # ticks. The PANIC latch prevents further caps —
                # subsequent attempts emit msg #130 (driver-side)
                # but don't shorten the timer further.
                if not $.panicked:
                    $.panicked = true
                    if $.timer > 15.0:
                        $.timer = 15.0
            }

            get_state(): String         { @@:("closing") }
            is_closing(): bool          { @@:(true) }
            in_repository(): bool       { @@:(false) }
            is_won(): bool              { @@:(false) }
            is_panicked(): bool         { @@:($.panicked) }
            treasures_count(): int      { @@:(self.treasures) }
            closing_timer(): float      { @@:($.timer) }
        }

        # ------------------------------------------------------------
        # $InRepository — player has been teleported, with all
        # treasures and a marker (TNT). The puzzle is to drop
        # everything except the marker and detonate it. Adventure
        # gates the verb table appropriately while we're here.
        # ------------------------------------------------------------
        $InRepository {
            detonate() {
                -> $Won
            }
            tick() {
                # No timer in the repository. Player has all the
                # time they want to figure the puzzle out.
            }
            treasure_deposited() {
                # Shouldn't happen — there's nowhere to deposit
                # a treasure inside the repository. Defensive
                # no-op.
            }
            panic() {
                # No-op — already past $Closing.
            }
            get_state(): String         { @@:("in_repository") }
            is_closing(): bool          { @@:(false) }
            in_repository(): bool       { @@:(true) }
            is_won(): bool              { @@:(false) }
            is_panicked(): bool         { @@:(false) }
            treasures_count(): int      { @@:(self.treasures) }
            closing_timer(): float      { @@:(0.0) }
        }

        # ------------------------------------------------------------
        # $Won — terminal. Player has escaped successfully.
        # ------------------------------------------------------------
        $Won {
            tick() {}
            treasure_deposited() {}
            detonate() {}
            panic() {}
            get_state(): String         { @@:("won") }
            is_closing(): bool          { @@:(false) }
            in_repository(): bool       { @@:(false) }
            is_won(): bool              { @@:(true) }
            is_panicked(): bool         { @@:(false) }
            treasures_count(): int      { @@:(self.treasures) }
            closing_timer(): float      { @@:(0.0) }
        }

    domain:
        # Tunables. Real CCA: 15 treasures, ~30-turn closing
        # warning. We ship matching counts for the canonical
        # version (10 of 15 triggers closing — the player
        # doesn't need every single treasure to "complete").
        TREASURES_TO_TRIGGER: int = 10
        CLOSING_DURATION: float = 30.0    # turns

        treasures: int = 0
}


# ------------------------------------------------------------
# Hint (parameterized × N — parallel small FSMs)
# ------------------------------------------------------------
# Each named hint is an instance of this 3-state machine.
# Adventure observes per-turn conditions and calls each
# hint's observe() with whether *its* trigger condition is
# true this turn. After the player has been in the trigger
# situation for `threshold` consecutive turns, the hint
# becomes available; the player can request_hint() to see it.
#
# State diagram:
#
#   $Pending   ── observe(true) × threshold ──► $Eligible
#              ── observe(false) ──► (streak resets)
#
#   $Eligible  ── request() ──► $Offered (returns hint text)
#
#   $Offered   (terminal — already given out)
#
# This is the canonical "many parallel small FSMs" pattern in
# CCA. Three to five named hints, each watching a different
# condition (bird room without taking, dark room, blocked at
# snake passage, two-pit-room, etc.). Per-hint state stays
# isolated; Adventure dispatches the same observe/request
# protocol to all of them.
#
# Frame's @@[persist] auto-traverses each named hint domain
# field, so save/restore preserves every hint's streak counter
# and current state independently. Hand-rolling the same
# behavior with a Dictionary of dictionaries would work, but
# you'd lose the "each hint is a typed thing with a query
# surface" structure.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Hint(threshold: int = 5) : RefCounted {

    interface:
        # Driver tells us whether OUR trigger condition is true
        # this turn. The hint counts consecutive trues; on
        # crossing threshold, becomes available.
        observe(condition_true: bool)

        # Player asked for the hint. If eligible, returns text
        # and transitions to $Offered. Otherwise returns the
        # canon "no hint available."
        request_hint(text_if_eligible: String): String

        get_state(): String
        is_eligible(): bool
        is_offered(): bool
        get_streak(): int

    machine:

        $Pending {
            observe(condition_true: bool) {
                if condition_true:
                    self.streak = self.streak + 1
                    if self.streak >= self.threshold:
                        -> $Eligible
                else:
                    self.streak = 0
            }
            request_hint(text_if_eligible: String): String {
                @@:("No hint available right now.")
            }
            get_state(): String     { @@:("pending") }
            is_eligible(): bool     { @@:(false) }
            is_offered(): bool      { @@:(false) }
            get_streak(): int       { @@:(self.streak) }
        }

        $Eligible {
            observe(condition_true: bool) {
                # Once eligible we stay eligible regardless of
                # streak — the player has the hint available
                # until they request or until they leave the
                # situation. (Real CCA actually re-arms; we
                # keep it simple.)
            }
            request_hint(text_if_eligible: String): String {
                -> $Offered
                @@:(text_if_eligible)
            }
            get_state(): String     { @@:("eligible") }
            is_eligible(): bool     { @@:(true) }
            is_offered(): bool      { @@:(false) }
            get_streak(): int       { @@:(self.streak) }
        }

        $Offered {
            observe(condition_true: bool) {}
            request_hint(text_if_eligible: String): String {
                @@:("That hint has already been given.")
            }
            get_state(): String     { @@:("offered") }
            is_eligible(): bool     { @@:(false) }
            is_offered(): bool      { @@:(true) }
            get_streak(): int       { @@:(self.streak) }
        }

    domain:
        threshold: int = threshold
        streak: int = 0
}


# ------------------------------------------------------------
# Dragon
# ------------------------------------------------------------
# CCA's most parser-iconic NPC. The canonical "ATTACK DRAGON"
# sequence requires a multi-turn interaction that's a perfect
# fit for state encoding the parser context across turns:
#
#   Player: ATTACK DRAGON
#   Game:   "With what, your bare hands?"
#   Player: YES
#   Game:   "You've defeated the dragon, congratulations."
#
# State diagram:
#
#   $Sleeping ── attack() ──► $Asked      (game prints prompt)
#   $Asked    ── yes() ──► $Dead          (player kills dragon)
#             ── no() ──► $Sleeping       (cancellation)
#             ── any other verb ──► $Sleeping
#                                        (also cancels — context is gone)
#
# The state machine here is doing real work: $Asked encodes
# "the parser is in a clarifying-question subdialog." Without
# the state, the driver would have to track this with a
# boolean flag set during the attack handler and checked at
# the start of the next command. Same flag-on-the-base smell
# the aspect bus pattern was extracted to avoid; here Frame
# keeps the context as part of the dragon's mode.
#
# After $Dead, the rug under the dragon and the eggs nearby
# become takeable (real CCA: this matters for treasure
# scoring). Adventure exposes is_alive() so the rest of the
# world can gate on dragon-killed.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Dragon : RefCounted {

    interface:
        attack()
        yes()
        no()
        cancel()       # any other verb — driver fires this on
                        #  unrelated input while $Asked
        get_state(): String
        is_alive(): bool
        is_awaiting_confirmation(): bool

    machine:

        $Sleeping {
            attack() {
                -> $Asked
            }
            yes() {}       # ignored outside the prompt
            no() {}
            cancel() {}
            get_state(): String                  { @@:("sleeping") }
            is_alive(): bool                     { @@:(true) }
            is_awaiting_confirmation(): bool     { @@:(false) }
        }

        $Asked {
            yes() {
                -> $Dead
            }
            no() {
                -> $Sleeping
            }
            cancel() {
                -> $Sleeping
            }
            attack() {
                # Re-asking — stay in $Asked.
            }
            get_state(): String                  { @@:("asked") }
            is_alive(): bool                     { @@:(true) }
            is_awaiting_confirmation(): bool     { @@:(true) }
        }

        $Dead {
            attack() {}    # idempotent
            yes() {}
            no() {}
            cancel() {}
            get_state(): String                  { @@:("dead") }
            is_alive(): bool                     { @@:(false) }
            is_awaiting_confirmation(): bool     { @@:(false) }
        }
}


# ------------------------------------------------------------
# Treasure (parameterized × 5 — composition data)
# ------------------------------------------------------------
# Each treasure is an instance of this 3-state system:
#
#   $InRoom     ── try_take(at_room) ──► $Carried
#   $Carried    ── try_drop(at_room) ──► $InRoom        (anywhere
#                                                         else)
#               ── try_drop(DEPOSIT_ROOM) ──► $Deposited
#
# Five named treasures in Adventure's domain (gold, silver,
# diamonds, jewelry, pearl) each parameterized with their home
# room and point value. Adventure's _verb_take / _verb_drop
# route the verb's noun to the right named treasure.
#
# When a treasure transitions to $Deposited, Adventure
# notifies endgame.treasure_deposited(), which in turn drives
# the $Active → $Closing transition once the threshold is
# crossed. Cross-FSM coordination, same shape as bird→snake
# and bear→troll.
#
# Real CCA has 15 treasures with various special handling
# (eggs disappear and reappear via FEE FIE FOE FOO, the rug
# is unreachable until the dragon dies, the pyramid only
# reveals after climbing a vine, etc.). This prototype models
# the canonical take/carry/deposit lifecycle on 5 treasures.
# Adding more is mechanical — same Treasure system,
# additional named instances, additional verb-noun branches.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Treasure(home_room: int = 0, value: int = 0, fragile: bool = false) : RefCounted {

    interface:
        try_take(at_room: int): bool       # true if successfully taken
        try_drop(at_room: int): String     # "dropped" / "deposited" / "broken" / error
        try_drop_soft(at_room: int): String # canonical soft landing — fragile survives (used by vase-on-pillow)
        reappear(at_room: int)              # used by Eggs incantation reset
        consume()                            # canon troll-toll: treasure thrown to troll vanishes irrevocably
        get_state(): String
        get_location(): int                # current room or -1 if carried
        get_value(): int
        is_deposited(): bool
        is_broken(): bool
        is_vanished(): bool

    machine:

        $InRoom {
            try_take(at_room: int): bool {
                if at_room == self.location_room:
                    -> $Carried
                    @@:return(true)
                @@:(false)
            }
            try_drop(at_room: int): String {
                @@:("not carried")
            }
            try_drop_soft(at_room: int): String {
                @@:("not carried")
            }
            reappear(at_room: int) {
                self.location_room = at_room
                # already $InRoom; just relocate
            }
            consume() {
                # Troll-toll path (or any future canon
                # destruction): treasure leaves the world entirely.
                -> $Vanished
            }
            get_state(): String      { @@:("in_room") }
            get_location(): int      { @@:(self.location_room) }
            get_value(): int         { @@:(self.value) }
            is_deposited(): bool     { @@:(false) }
            is_broken(): bool        { @@:(false) }
            is_vanished(): bool      { @@:(false) }
        }

        $Carried {
            try_take(at_room: int): bool {
                @@:(false)             # already carrying
            }
            try_drop(at_room: int): String {
                self.location_room = at_room
                if at_room == self.DEPOSIT_ROOM:
                    -> $Deposited
                    @@:return("deposited")
                # Fragile treasures shatter on a non-deposit
                # drop. Real CCA: the velvet pillow saves the
                # vase — Adventure brokers that case via
                # try_drop_soft below.
                if self.fragile:
                    -> $Broken
                    @@:return("broken")
                -> $InRoom
                @@:("dropped")
            }
            try_drop_soft(at_room: int): String {
                # Soft landing: caller has verified a pillow (or
                # equivalent canonical cushion) is present in
                # the room. Fragile survives in this case.
                self.location_room = at_room
                if at_room == self.DEPOSIT_ROOM:
                    -> $Deposited
                    @@:return("deposited")
                -> $InRoom
                @@:("dropped_soft")
            }
            reappear(at_room: int) {
                # Magic-summon while carried: snap into the
                # target room and drop carrying. Used by the
                # Eggs incantation.
                self.location_room = at_room
                -> $InRoom
            }
            consume() {
                # Throwing a carried treasure to the troll
                # vanishes it from the world. Adventure layer
                # remains responsible for self.player.drop()
                # and the troll.scared_off().
                -> $Vanished
            }
            get_state(): String      { @@:("carried") }
            get_location(): int      { @@:(-1) }
            get_value(): int         { @@:(self.value) }
            is_deposited(): bool     { @@:(false) }
            is_broken(): bool        { @@:(false) }
            is_vanished(): bool      { @@:(false) }
        }

        $Deposited {
            try_take(at_room: int): bool {
                @@:(false)             # treasure is locked in deposit room
            }
            try_drop(at_room: int): String {
                @@:("already deposited")
            }
            try_drop_soft(at_room: int): String {
                @@:("already deposited")
            }
            reappear(at_room: int) {
                # FEE FIE FOE FOO can summon eggs back even
                # after they were deposited (canon CCA gives
                # a chuckle and resets eggs to the giant room
                # but doesn't credit the deposit twice; we
                # match that — the score has already been
                # awarded, and now the eggs are back in play).
                self.location_room = at_room
                -> $InRoom
            }
            consume() {
                # No-op: a deposited treasure is locked in.
            }
            get_state(): String      { @@:("deposited") }
            get_location(): int      { @@:(self.DEPOSIT_ROOM) }
            get_value(): int         { @@:(self.value) }
            is_deposited(): bool     { @@:(true) }
            is_broken(): bool        { @@:(false) }
            is_vanished(): bool      { @@:(false) }
        }

        $Broken {
            try_take(at_room: int): bool {
                @@:(false)             # shards aren't a treasure
            }
            try_drop(at_room: int): String {
                @@:("already broken")
            }
            try_drop_soft(at_room: int): String {
                @@:("already broken")
            }
            reappear(at_room: int) {
                # Incantation can't un-break a thing.
            }
            consume() {}
            get_state(): String      { @@:("broken") }
            get_location(): int      { @@:(self.location_room) }
            get_value(): int         { @@:(0) }
            is_deposited(): bool     { @@:(false) }
            is_broken(): bool        { @@:(true) }
            is_vanished(): bool      { @@:(false) }
        }

        # ------------------------------------------------------------
        # $Vanished — quasi-terminal state for treasures the troll
        # caught (canon bridge-toll). Most treasures stay here
        # forever once given to the troll, but eggs are special:
        # the FEE FIE FOE FOO incantation canonically yanks them
        # back to the giant chamber regardless of their location
        # (per ODWY0350/advent.c — `move(EGGS, R_GIANT)` fires even
        # when EGGS are at R_LIMBO via the troll). The incantation
        # invokes `reappear(at_room)` on the eggs; we honor it by
        # transitioning back to $InRoom. Other treasures are never
        # subjected to a post-throw `reappear()` call (the
        # incantation is eggs-only in `_verb_chant`), so they stay
        # vanished as canon dictates.
        # ------------------------------------------------------------
        $Vanished {
            try_take(at_room: int): bool        { @@:(false) }
            try_drop(at_room: int): String      { @@:("vanished") }
            try_drop_soft(at_room: int): String { @@:("vanished") }
            reappear(at_room: int) {
                self.location_room = at_room
                -> $InRoom
            }
            consume()                            {}
            get_state(): String       { @@:("vanished") }
            get_location(): int       { @@:(-1) }
            get_value(): int          { @@:(0) }
            is_deposited(): bool      { @@:(false) }
            is_broken(): bool         { @@:(false) }
            is_vanished(): bool       { @@:(true) }
        }

    domain:
        home_room: int = home_room
        value: int = value
        fragile: bool = fragile
        location_room: int = home_room
        DEPOSIT_ROOM: int = 3            # canonical: well house
}


# ------------------------------------------------------------
# Item (parameterized × N — non-treasure carryables)
# ------------------------------------------------------------
# Generic carryable-or-fixture object. Sister aspect to
# Treasure: same $InRoom / $Carried shape, but no $Deposited
# / fragile semantics. Adds a $Consumed terminal for items
# that get eaten (food → bear), used up (batteries → lamp),
# or destroyed (clam → broken when player BREAKs it).
#
# Replaces twelve hand-rolled `*_carried: bool + *_location:
# int` pairs that used to be scattered across Adventure's
# domain. Each item is now one parameterized instance:
#
#     rod        = @@Item(11)           # debris room
#     keys       = @@Item(3)            # well house
#     bottle     = @@Item(3)            # well house
#     cage       = @@Item(10)           # cobble crawl
#     food       = @@Item(3)            # well house
#     pillow     = @@Item(96)           # Soft Room
#     clam       = @@Item(103)          # Shell Room
#     magazine   = @@Item(106)          # Anteroom
#     axe        = @@Item(-1)           # not in world (dwarf-thrown)
#     mark_rod   = @@Item(-1)           # not in world (slain dwarf)
#     batteries  = @@Item(-1)           # not in world (vending dispensed)
#     oyster     = @@Item(-1)           # not in world (clam-broken)
#
# Items with home_room <= 0 sit in $InRoom with location <= 0
# — that's the "not yet in the world" representation. The
# `place(at_room)` event puts them somewhere; `try_take` will
# only succeed once they're in a real room.
#
# Events:
#   try_take(at_room) → bool  — true if successfully taken
#   try_drop(at_room) → bool  — true if successfully dropped
#   place(at_room)            — relocate (dwarf throw, vending
#                              dispense, clam break); valid in
#                              any state, transitions to $InRoom
#   consume()                 — terminal, removes from world
#                              (food eaten, batteries used,
#                              clam broken)
#
# The bottle's contents (Empty / Water / Oil) stay on the
# Bottle FSM; only the carry/location dimension migrates here.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Item(home_room: int = -1) : RefCounted {

    interface:
        try_take(at_room: int): bool
        try_drop(at_room: int): bool
        place(at_room: int)
        consume()
        is_carried(): bool
        is_in_room(r: int): bool
        get_state(): String
        get_location(): int

    machine:

        $InRoom {
            try_take(at_room: int): bool {
                if self.location > 0 and at_room == self.location:
                    -> $Carried
                    @@:return(true)
                @@:(false)
            }
            try_drop(at_room: int): bool {
                @@:(false)
            }
            place(at_room: int) {
                self.location = at_room
            }
            consume() {
                self.location = -1
                -> $Consumed
            }
            is_carried(): bool       { @@:(false) }
            is_in_room(r: int): bool { @@:(self.location > 0 and r == self.location) }
            get_state(): String      { @@:("in_room") }
            get_location(): int      { @@:(self.location) }
        }

        $Carried {
            try_take(at_room: int): bool {
                @@:(false)
            }
            try_drop(at_room: int): bool {
                self.location = at_room
                -> $InRoom
                @@:return(true)
            }
            place(at_room: int) {
                self.location = at_room
                -> $InRoom
            }
            consume() {
                self.location = -1
                -> $Consumed
            }
            is_carried(): bool       { @@:(true) }
            is_in_room(r: int): bool { @@:(false) }
            get_state(): String      { @@:("carried") }
            get_location(): int      { @@:(-1) }
        }

        $Consumed {
            try_take(at_room: int): bool {
                @@:(false)
            }
            try_drop(at_room: int): bool {
                @@:(false)
            }
            place(at_room: int) {
                self.location = at_room
                -> $InRoom
            }
            consume() {}
            is_carried(): bool       { @@:(false) }
            is_in_room(r: int): bool { @@:(false) }
            get_state(): String      { @@:("consumed") }
            get_location(): int      { @@:(-1) }
        }

    domain:
        # `home_room` is mirrored as a domain field so that the
        # codegen'd save/restore can pass it back to `Item.new()`
        # on rehydrate. Treasure does the same with its three
        # construction parameters; following that pattern keeps
        # @@[persist] round-tripping clean.
        home_room: int = home_room
        location: int = home_room
}


# ------------------------------------------------------------
# EggsIncantation
# ------------------------------------------------------------
# CCA's most parser-poetic mechanic: the player chants
# FEE FIE FOE FOO and the eggs (taken from the Giant Room)
# magically reappear there. Breaks the chant on any other
# verb. Modeled as a 4-state sequence FSM:
#
#   $Idle ── say("fee") ──► $WaitingFie
#   $WaitingFie ── say("fie") ──► $WaitingFoe
#                ── say(other) ──► $Idle
#   $WaitingFoe ── say("foe") ──► $WaitingFoo
#                ── say(other) ──► $Idle
#   $WaitingFoo ── say("foo") ──► $Idle (with side effect:
#                                        Adventure summons
#                                        eggs back)
#                ── say(other) ──► $Idle
#
# The side effect (eggs.reappear) is dispatched by Adventure
# observing the FSM after each say() call: if the just-chanted
# word was "foo" AND the prior state was $WaitingFoo, the
# chant completed. Adventure handles the cross-FSM call
# rather than baking it into EggsIncantation, keeping each
# system testable in isolation.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system EggsIncantation : RefCounted {

    interface:
        say(word: String): String       # returns canonical reply
        get_state(): String

    machine:

        $Idle {
            say(word: String): String {
                if word == "fee":
                    -> $WaitingFie
                    @@:return("Fie?")
                @@:("Nothing happens.")
            }
            get_state(): String  { @@:("idle") }
        }

        $WaitingFie {
            say(word: String): String {
                if word == "fie":
                    -> $WaitingFoe
                    @@:return("Foe?")
                -> $Idle
                @@:("You broke the chant.")
            }
            get_state(): String  { @@:("waiting_fie") }
        }

        $WaitingFoe {
            say(word: String): String {
                if word == "foe":
                    -> $WaitingFoo
                    @@:return("Foo?")
                -> $Idle
                @@:("You broke the chant.")
            }
            get_state(): String  { @@:("waiting_foe") }
        }

        $WaitingFoo {
            # On "foo" we transition back to $Idle and return the
            # completion message. The actual side effect (summoning
            # eggs back to the giant room) is dispatched by Adventure
            # after observing this transition — keeping each FSM
            # responsible for its own slice of behavior.
            say(word: String): String {
                if word == "foo":
                    -> $Idle
                    @@:return("Done!")
                -> $Idle
                @@:("You broke the chant.")
            }
            get_state(): String  { @@:("waiting_foo") }
        }
}


# ------------------------------------------------------------
# CrystalBridge
# ------------------------------------------------------------
# Two-state FSM that gates the fissure crossing. Canon CCA: a
# black rod (with a star, in the canonical original; we just
# call it "the rod") is found in the Debris Room. Waving the
# rod at the fissure causes a crystal bridge to materialize
# spanning it; waving the rod again causes the bridge to fade.
# The bridge is the only way to reach the rooms beyond the
# fissure.
#
# State diagram:
#
#   $NoBridge ── wave() ──► $Bridge      (rod must be in hand
#                                          AND player must be at
#                                          the fissure room —
#                                          guarded by Adventure
#                                          before this verb is
#                                          dispatched)
#   $Bridge   ── wave() ──► $NoBridge    (toggling re-fades it)
#
# Frame value: tiny FSM (two states) but the toggling
# transition + persistence + queryable `is_built()` slot in
# cleanly. The orchestration smarts (rod-in-hand, player-at-
# fissure) live in Adventure where the cross-FSM context is
# available; the bridge itself only knows its own toggle. This
# is the same separation-of-concerns pattern that drove the
# bird→snake and bear→troll wiring: each NPC owns its slice,
# Adventure brokers the rest.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system CrystalBridge : RefCounted {

    interface:
        wave(): String
        get_state(): String
        is_built(): bool

    machine:

        $NoBridge {
            wave(): String  {
                -> $Bridge
                @@:return("A crystal bridge now spans the fissure!")
            }
            get_state(): String  { @@:("no_bridge") }
            is_built(): bool     { @@:(false) }
        }

        $Bridge {
            wave(): String  {
                -> $NoBridge
                @@:return("The crystal bridge shimmers and vanishes.")
            }
            get_state(): String  { @@:("built") }
            is_built(): bool     { @@:(true) }
        }
}


# ------------------------------------------------------------
# Grate
# ------------------------------------------------------------
# Canonical CCA's first gating puzzle: a steel grate set into
# the depression floor (room 8). It starts $Locked. Inside the
# well house (room 3) sit some keys, which the player must take
# and bring to the grate to unlock it.
#
# Architecturally this is the same shape as CrystalBridge — a
# tiny two-state FSM with an `unlock(have_keys: bool)` guarded
# transition. We add it for canon completeness rather than for
# new-pattern demonstration value; the Frame brain doesn't grow,
# but the player's first canonical CCA experience now matches
# what every other port renders.
#
# State diagram:
#
#   $Locked   ── unlock(have_keys=true)  ──► $Unlocked
#   $Unlocked ── lock()                   ──► $Locked
#                  (re-locks; canon allows this both ways)
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Grate : RefCounted {

    interface:
        unlock(have_keys: bool): String
        lock(): String
        get_state(): String
        is_locked(): bool

    machine:

        $Locked {
            unlock(have_keys: bool): String  {
                if have_keys:
                    -> $Unlocked
                    @@:return("The grate is now unlocked.")
                # Canon msg #31.
                @@:("You have no keys!")
            }
            # Canon msg #34.
            lock(): String           { @@:("It was already locked.") }
            get_state(): String      { @@:("locked") }
            is_locked(): bool        { @@:(true) }
        }

        $Unlocked {
            # Canon msg #37.
            unlock(have_keys: bool): String  { @@:("It was already unlocked.") }
            lock(): String           {
                -> $Locked
                @@:return("The grate is now locked.")
            }
            get_state(): String      { @@:("unlocked") }
            is_locked(): bool        { @@:(false) }
        }
}


# ------------------------------------------------------------
# RustyDoor
# ------------------------------------------------------------
# Canon: at the north end of the immense N/S passage (canon 94),
# a rusty door blocks the way to the Magnificent Cavern (canon
# 95) where the trident treasure waits. The door's hinges are
# stuck. Pouring oil from the bottle (filled at canon 105's
# Pool of Oil) frees them, after which NORTH/ENTER/CAVERN at 94
# all walk through to 95.
#
# Canon section 2 encodes the puzzle as two rows on the same
# verb cluster:
#   `94 309095 45 3 73`   conditional on cond 309 (door oiled)
#                         → 95 via N/ENTER/CAVERN
#   `94 611 45`           fallback msg #111 ("rusty refuses")
#
# Two-state FSM (same shape as Grate). The transition is one-
# way: there's no "rust the door again" verb in canon. Save/
# restore round-trips the state so resumption preserves whether
# the player has progressed past the puzzle.
#
# State diagram:
#
#   $Rusty ── oil() ──► $Oiled (terminal)
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system RustyDoor : RefCounted {

    interface:
        oil(): String
        get_state(): String
        is_rusty(): bool

    machine:

        $Rusty {
            oil(): String  {
                -> $Oiled
                @@:return("The oil has freed up the hinges so that the door will now move, although it requires some effort.")
            }
            get_state(): String      { @@:("rusty") }
            is_rusty(): bool         { @@:(true) }
        }

        $Oiled {
            oil(): String            { @@:("The hinges are already well-lubricated.") }
            get_state(): String      { @@:("oiled") }
            is_rusty(): bool         { @@:(false) }
        }
}


# ------------------------------------------------------------
# VendingMachine
# ------------------------------------------------------------
# Canon CCA Easter egg: at the Vending Machine Room (95) the
# player can insert the rare-coins treasure to receive fresh
# batteries. Two-state FSM with a single side-effect-bearing
# transition. Adventure brokers the cross-FSM choreography:
#   - removes coins from the player's inventory
#   - relocates coins out of bounds (consuming them; player
#     loses the points they'd score by depositing them at the
#     well house, which is the actual puzzle decision)
#   - calls lamp.refresh() so the new batteries take effect
#
# Why this earns a tiny FSM rather than a single function:
# the Empty-after-use state matters for repeat behavior — once
# the machine has been used, inserting more coins (somehow) is
# not the canon behavior, and a $Used state is easier to read
# than a `vending_used: bool` flag scattered through Adventure.
# Also: this is the first Frame system that demonstrates
# *consume-an-item* as a transition outcome, vs the existing
# patterns of relocate (Pirate/Treasure) or transition-only
# (CrystalBridge/Grate).
#
# State diagram:
#
#   $Loaded ── insert(have_coins=true)  ──► $Empty
#   $Empty                                  terminal
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system VendingMachine : RefCounted {

    interface:
        insert(have_coins: bool): String
        get_state(): String
        is_loaded(): bool

    machine:

        $Loaded {
            insert(have_coins: bool): String  {
                if have_coins:
                    -> $Empty
                    @@:return("The vending machine clanks twice and dispenses a fresh set of lamp batteries.")
                @@:("You don't have any coins to insert.")
            }
            get_state(): String      { @@:("loaded") }
            is_loaded(): bool        { @@:(true) }
        }

        $Empty {
            insert(have_coins: bool): String  {
                @@:("The vending machine is empty. The hand-lettered sign now reads 'OUT OF BATTERIES'.")
            }
            get_state(): String      { @@:("empty") }
            is_loaded(): bool        { @@:(false) }
        }
}


# ------------------------------------------------------------
# Bottle
# ------------------------------------------------------------
# The water bottle from the well house. A 3-state container
# tracking whether it currently holds water, oil, or nothing.
# The bottle is also an inventory item — its location/carry
# state lives on Adventure as `bottle_item` (an `Item`
# parameterized FSM). The FSM here just tracks contents.
#
# State diagram:
#
#   $Empty ── fill(at_water_source=true) ──► $Water
#   $Water ── pour() ──► $Empty
#   $Water ── drink() ──► $Empty
#
# Cross-FSM choreography (Adventure brokers):
#   - FILL only succeeds at a water-source room (3, 4, 83, 84).
#   - POUR on the plant triggers `plant.water()`.
#   - POUR anywhere else just empties the bottle for flavor.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Bottle : RefCounted {

    interface:
        fill(at_water_source: bool): String
        fill_oil(at_oil_source: bool): String
        pour(): String
        drink(): String
        get_state(): String
        has_water(): bool
        has_oil(): bool

    machine:

        $Empty {
            fill(at_water_source: bool): String  {
                # Canon msg #107 / #106.
                if at_water_source:
                    -> $Water
                    @@:return("Your bottle is now full of water.")
                @@:("There is nothing here with which to fill the bottle.")
            }
            fill_oil(at_oil_source: bool): String  {
                # Canon msg #108 / #106.
                if at_oil_source:
                    -> $Oil
                    @@:return("Your bottle is now full of oil.")
                @@:("There is nothing here with which to fill the bottle.")
            }
            pour(): String           { @@:("The bottle is empty.") }
            drink(): String          { @@:("The bottle is empty.") }
            get_state(): String      { @@:("empty") }
            has_water(): bool        { @@:(false) }
            has_oil(): bool          { @@:(false) }
        }

        $Water {
            fill(at_water_source: bool): String  {
                # Canon msg #105.
                @@:("Your bottle is already full.")
            }
            fill_oil(at_oil_source: bool): String  {
                @@:("The bottle is full of water — empty it first.")
            }
            pour(): String           {
                # Canon msg #77: "YOUR BOTTLE IS EMPTY AND THE GROUND IS WET."
                -> $Empty
                @@:return("Your bottle is empty and the ground is wet.")
            }
            drink(): String          {
                # Canon: drinking from the bottle drains it. Canon
                # msg #74 verbatim. Stream-drink (msg #73) is
                # rendered separately when player drinks at a
                # water source instead of from the bottle.
                -> $Empty
                @@:return("The bottle of water is now empty.")
            }
            get_state(): String      { @@:("water") }
            has_water(): bool        { @@:(true) }
            has_oil(): bool          { @@:(false) }
        }

        $Oil {
            fill(at_water_source: bool): String  {
                @@:("The bottle is full of oil — empty it first.")
            }
            fill_oil(at_oil_source: bool): String  {
                @@:("The bottle is already full of oil.")
            }
            pour(): String           {
                -> $Empty
                @@:return("The oil pours out, soaking into whatever is beneath you.")
            }
            drink(): String          {
                @@:("Drink that?  Don't be ridiculous.")
            }
            get_state(): String      { @@:("oil") }
            has_water(): bool        { @@:(false) }
            has_oil(): bool          { @@:(true) }
        }
}


# ------------------------------------------------------------
# Plant
# ------------------------------------------------------------
# The beanstalk in the West Pit (room 23). Canonically a 3-stage
# growth chain driven by waterings: Tiny → Tall (one water) →
# Huge (two waters). $Tall lets the player climb to the middle
# section (room 24); $Huge lets them climb all the way to the
# top (room 25). Without water, the plant is too feeble to
# climb at all.
#
# State diagram:
#
#   $Tiny ── water() ──► $Tall
#   $Tall ── water() ──► $Huge
#   $Huge      terminal (already enormous)
#
# Adventure brokers: `_verb_pour("water")` at the West Pit
# calls `plant.water()` AND empties the bottle. The driver
# gates the climb exits (23→24, 24→25) on the plant's state.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Plant : RefCounted {

    interface:
        water(): String
        get_state(): String
        is_tall(): bool          # climbable to room 24
        is_huge(): bool          # climbable to room 25

    machine:

        $Tiny {
            water(): String          {
                -> $Tall
                @@:return("The plant grows ten feet, towering above you.")
            }
            get_state(): String      { @@:("tiny") }
            is_tall(): bool          { @@:(false) }
            is_huge(): bool          { @@:(false) }
        }

        $Tall {
            water(): String          {
                -> $Huge
                @@:return("The plant grows another fifty feet, vanishing into the gloom above.")
            }
            get_state(): String      { @@:("tall") }
            is_tall(): bool          { @@:(true) }
            is_huge(): bool          { @@:(false) }
        }

        $Huge {
            water(): String          { @@:("The plant is already enormous.") }
            get_state(): String      { @@:("huge") }
            is_tall(): bool          { @@:(true) }
            is_huge(): bool          { @@:(true) }
        }
}


# ------------------------------------------------------------
# Pirate
# ------------------------------------------------------------
# Three-state probabilistic encounter, similar in shape to a
# Dwarf but with one steal-and-vanish rather than a chain of
# attacks. Activates when the player's treasure-carry count
# crosses a threshold; once active, has a per-turn chance to
# spawn into the player's room and steal one treasure. After
# stealing, vanishes to the chest room (where the player can
# eventually retrieve the stolen loot).
#
# State diagram:
#
#   $Dormant ── treasures_carried(n) ──► $Stalking
#                  (when n >= ACTIVATION_THRESHOLD)
#   $Stalking ── try_steal(seed_step) ──► $Vanished
#                  (if probabilistic roll succeeds — stolen!)
#   $Vanished      terminal
#
# Adventure observes player.inventory_size each turn and calls
# treasures_carried; a successful steal reduces the player's
# treasure count and the Adventure surfaces the "rrrgh!" message.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Pirate(seed: int = 42) : RefCounted {

    interface:
        treasures_carried(n: int)
        try_steal(): bool                # returns true if pirate stole
        get_state(): String
        is_stalking(): bool

    machine:

        $Dormant {
            treasures_carried(n: int) {
                if n >= self.ACTIVATION_THRESHOLD:
                    -> $Stalking
            }
            try_steal(): bool {
                @@:(false)
            }
            get_state(): String  { @@:("dormant") }
            is_stalking(): bool  { @@:(false) }
        }

        $Stalking {
            treasures_carried(n: int) {
                # Already stalking; staying here is fine.
                # No re-trigger.
            }
            try_steal(): bool {
                # 25% chance per turn — same deterministic PRNG
                # shape as Dwarf.attack().
                self.step = self.step + 1
                var x: int = self.seed * 1664525 + self.step * 1013904223
                x = ((x >> 16) ^ x) * 22695477
                x = x & 0xffffffff
                var roll: int = x % 100
                if roll < 25:
                    -> $Vanished
                    @@:return(true)
                @@:(false)
            }
            get_state(): String  { @@:("stalking") }
            is_stalking(): bool  { @@:(true) }
        }

        $Vanished {
            treasures_carried(n: int) {}
            try_steal(): bool {
                @@:(false)
            }
            get_state(): String  { @@:("vanished") }
            is_stalking(): bool  { @@:(false) }
        }

    domain:
        seed: int = seed
        step: int = 0
        ACTIVATION_THRESHOLD: int = 3
}


# ------------------------------------------------------------
# ScoreLedger (aspect)
# ------------------------------------------------------------
# Demonstrates the *observe* verdict. ScoreLedger watches
# every event that reaches it, records what happened, and
# always returns "observe" — never blocking or transforming.
# The purpose is telemetry / score: count commands, count
# specific verbs, accumulate points.
#
# In real CCA, scoring has roughly seven components — treasures
# deposited, rooms visited, hints used, deaths, endgame bonus,
# etc. — each scoring rule turns out to be "observe a specific
# event class and add a number." That's a natural fit for an
# observe aspect: the rules are completely orthogonal to the
# verb dispatch logic that already exists; scoring shouldn't
# need to be threaded through it.
#
# This prototype version just counts. Per-rule scoring goes
# in once we have treasures and a deposit room.
# ------------------------------------------------------------
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system ScoreLedger : RefCounted {

    interface:
        try_handle(event: Dictionary): Dictionary
        get_score(): int
        commands_seen(): int
        takes_seen(): int

    machine:

        $Active {
            try_handle(event: Dictionary): Dictionary {
                self.commands = self.commands + 1
                var verb: String = event.get("verb", "")
                if verb == "take":
                    self.takes = self.takes + 1
                    # Placeholder per-take score. Real CCA
                    # awards points based on which treasure
                    # was just deposited (not taken); refine
                    # when treasures land.
                    self.score = self.score + 1
                @@:({"verdict": "observe", "event": event})
            }

            get_score(): int      { @@:(self.score) }
            commands_seen(): int  { @@:(self.commands) }
            takes_seen(): int     { @@:(self.takes) }
        }

    domain:
        score: int = 0
        commands: int = 0
        takes: int = 0
}


# ------------------------------------------------------------
# Adventure (top-level orchestrator)
# ------------------------------------------------------------
# Holds the world: bus + aspects + player + lamp (so far).
# Drives publish() through the verdict ladder, falling back to
# a base verb dispatcher when no aspect consumes.
#
# Each command goes through:
#   1. Build event Dictionary with verb/noun + world snapshot
#      (the facts aspects need to make decisions)
#   2. bus.begin_dispatch()
#   3. Walk bus.ordered_names(), call _dispatch_to for each
#   4. On consume: capture the message and stop
#   5. On transform: continue with the new event
#   6. bus.end_dispatch()
#   7. If not consumed: route to the base verb handler
#
# The driver doesn't see this orchestration — it just calls
# do_command(verb, noun) and reads back a String message.
# ------------------------------------------------------------
@@[main]
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Adventure : RefCounted {

    interface:
        # Lifecycle
        setup_default_aspects()

        # Per-turn entry. Returns the message for the player.
        do_command(verb: String, noun: String): String

        # Tick (npc updates, lamp battery, etc). Called once
        # per command turn, after do_command.
        tick()

        # Lamp control — surfaced for direct driver use during
        # bootstrap / tests. Real flow goes through do_command
        # with verb="light" / "extinguish".
        light_lamp()
        extinguish_lamp()
        refresh_lamp()

        # Queries — flat surface area for the driver to read.
        get_lamp_state(): String
        get_lamp_message(): String
        is_lit(): bool
        battery_left(): int
        turn_count(): int
        player_room(): int
        player_state(): String
        room_is_dark_now(): bool
        darkness_consumed_count(): int
        backpack_blocked_count(): int
        magic_transforms_count(): int
        score(): int
        commands_seen(): int

        # NPC queries
        bird_state(): String
        bird_location(): int
        snake_state(): String
        bear_state(): String
        bear_dangerous(): bool
        troll_state(): String
        troll_blocking(): bool
        # Canon msgs #161/#162 — the troll bridge collapses if the
        # player crosses it with the bear following. Tracked here
        # (rather than on a Bridge FSM) because canon's behavior
        # only needs a single one-shot terminal flag — once the
        # bridge falls, every future cross attempt at canon 117 or
        # 122 emits msg #161 ("There is no longer any way across
        # the chasm.").
        troll_bridge_collapsed(): bool
        collapse_troll_bridge()

        # Scoring breakdown — driver renders these in the
        # SCORE command. CCA-canonical components:
        #   treasure_score: sum of values of deposited treasures
        #   visit_score:    one point per unique room visited
        #   hint_penalty:   -2 per accepted hint
        #   endgame_score:  +50 for successful escape
        # `score()` already returns the rolled-up total above.
        treasure_score(): int
        visit_score(): int
        hint_penalty(): int
        endgame_score(): int

        # Dwarves (5 parameterized instances).
        wake_dwarves()
        attack_dwarf_in_room(): String        # tries the dwarf at player's location
        living_dwarves(): int
        dwarf_threw_axe(): bool               # latched flag — driver reads & clears
        bump_dwarf_anger()                    # FEED dwarf increments anger (canon DFLAG++)
        get_dwarf_anger(): int                # current dwarf anger (canon DFLAG, floor 2)

        # Endgame
        deposit_treasure()
        detonate_marker()
        # Canon BLAST verb (advent.for STMT 9230) has three
        # outcomes when fired in the repository ($InRepository
        # state in the port), each awarding a different bonus:
        #   blast_mastery    — rod2 NOT here AND not at canon 115
        #                       canon msg #133, score +45.
        #   blast_wrong_way  — rod2 NOT here, but player at 115
        #                       canon msg #134, score +30.
        #   blast_klutz      — rod2 here (player blew themselves up)
        #                       canon msg #135, score +25.
        # All three transition Endgame to $Won. Pre-CLOSED BLAST
        # is a no-op handled at the driver layer (msg #54).
        blast_mastery()
        blast_wrong_way()
        blast_klutz()
        endgame_state(): String
        endgame_closing(): bool
        endgame_won(): bool
        endgame_timer(): float
        endgame_panic()                       # canon CLOCK2 cap on PANIC
        endgame_panicked(): bool

        # Hints (parameterized × 3 parallel)
        request_hint(name: String): String
        hint_state(name: String): String

        # Dragon (multi-turn parser dialog)
        dragon_state(): String
        dragon_alive(): bool

        # Pirate (probabilistic encounter)
        pirate_state(): String
        pirate_try_steal(): bool
        # Higher-level wrapper: rolls the pirate's steal, picks a
        # treasure from the player's inventory in deterministic
        # order, relocates it to the chest room (canon CCA's
        # pirate hoard), and returns the user-visible message.
        # Returns "" when nothing was stolen.
        pirate_attempt_steal(): String

        # Treasures
        treasures_deposited(): int
        total_score(): int

        # CrystalBridge / rod (the fissure puzzle)
        bridge_built(): bool
        rod_in_inventory(): bool
        # Canon `HERE(ROD2)` query — the marked decoy rod is at
        # the player's location either because they carry it or
        # because it's been placed in their current room. Used
        # by the BLAST verb's outcome selection (klutz vs.
        # mastery vs. wrong-way), where rod2-here means "the
        # dynamite is in the room with you."
        mark_rod_here(): bool
        grate_locked(): bool
        rusty_door_oiled(): bool
        keys_in_inventory(): bool
        vending_loaded(): bool
        plant_is_tall(): bool
        plant_is_huge(): bool
        bottle_in_inventory(): bool
        bottle_has_water(): bool
        # Canon Plover-tunnel squeeze gate: the alcove (99) ↔
        # Plover Room (100) is a hand-and-knees crawl too tight
        # to carry anything except the emerald (which is small
        # enough). Returns true while the player is carrying
        # disqualifying items.
        plover_squeeze_blocked(): bool

    machine:

        $Playing {

            setup_default_aspects() {
                # Priority order matters. Higher fires first.
                #
                #   darkness (700) — gates info verbs first; if
                #     consumed, downstream aspects don't run
                #     (no need to evaluate magic words in a
                #     dark room when the player can't see).
                #   backpack (400) — gates take when full,
                #     before any per-item logic.
                #   magic    (500) — transforms magic-word
                #     verbs into MOVE; placed above backpack
                #     so a transformed event still runs through
                #     the lower-priority aspects on the way to
                #     base, but below darkness (you don't want
                #     XYZZY to silently teleport you while
                #     you're literally unable to see).
                self.bus.register("darkness", 700)
                self.bus.register("magic",    500)
                self.bus.register("backpack", 400)
                # ScoreLedger sits at the bottom of the stack
                # so it observes events AFTER any transforms
                # higher up have applied. A magic-word
                # teleport, by the time score sees it, looks
                # like a "move" — that's intentional; the
                # ledger should record "the player moved" not
                # "the player typed XYZZY."
                self.bus.register("score",    100)
            }

            do_command(verb: String, noun: String): String {
                # Build the per-event world snapshot. Aspects
                # read what they need from this Dictionary; we
                # don't pass them references to Adventure.
                var event: Dictionary = {
                    "verb": verb,
                    "noun": noun,
                    "room": self.player.get_room(),
                    "is_dark": self._room_is_dark(self.player.get_room()),
                    "lamp_lit": self.lamp.is_lit(),
                    "carrying_count": self.player.inventory_size(),
                }

                self.bus.begin_dispatch()
                var names: Array = self.bus.ordered_names()
                var i: int = 0
                var consume_message: String = ""
                while i < names.size():
                    var aname: String = names[i]
                    var result: Dictionary = self._dispatch_to(aname, event)
                    var verdict: String = result.verdict
                    if verdict == "consume":
                        consume_message = result.get("message", "")
                        i = names.size()
                    elif verdict == "transform":
                        event = result.event
                    i = i + 1
                self.bus.end_dispatch()

                if consume_message != "":
                    @@:return(consume_message)

                @@:(self._base_handle(event))
            }

            tick() {
                self.lamp.tick()
                self.endgame.tick()
                # Cave-closing teleport. Canon CCA whisks the player
                # to the SW Repository (canon room 116) the moment
                # endgame's closing-timer drains. Rising-edge guard
                # — fires on the first tick after $Closing → $InRepository
                # transitions, then leaves the player free to move within
                # 115/116 (canonically the cave seals around them, but
                # we don't enforce that here).
                if self.endgame.in_repository() and not self.repository_teleport_done:
                    self.player.move_to(self.REPOSITORY_ROOM)
                    self.repository_teleport_done = true
                # Per-turn hint observation. Each hint watches
                # a different world condition; Adventure
                # decides what each hint cares about and
                # tells it whether the trigger is true this
                # turn. Hints handle their own streak/timeout
                # logic.
                var r: int = self.player.get_room()
                self.bird_hint.observe(
                    r == self.BIRD_HOME_ROOM and self.bird.get_state() == "free")
                self.snake_hint.observe(
                    r == self.SNAKE_ROOM and self.snake.is_blocking())
                # Canon hint #62/#63: cave-entry hint fires when
                # the player has wandered the surface (rooms 1-9)
                # without finding a way in. The grate-and-keys
                # combo is the canonical answer.
                self.cave_hint.observe(r >= 1 and r <= 9)
                # Canon hint #176/177: maze hint when in the
                # twisty-passage rooms — first maze (50-57) or
                # second maze (131-139).
                self.maze_hint.observe(
                    (r >= 50 and r <= 57) or (r >= 131 and r <= 139))
                # Canon hint #178/179: Plover-exploration hint when
                # in the Plover Room (100) struggling for direction.
                self.plover_hint.observe(r == self.PLOVER_ROOM)
                # Canon hint #180/181: Witt's End hint at canon
                # room 108 — the "DON'T GO WEST" advice.
                self.witts_hint.observe(r == self.WITTS_END_ROOM)
                # Canon dwarf-awakening: dwarves activate after the
                # player has spent ~13 turns in the deep cave. We
                # mirror that with an auto-wake counter; tests can
                # still call wake_dwarves() explicitly to bypass.
                if r >= 14 and r <= 130 and not self.dwarves_auto_woken:
                    self.deep_cave_turns = self.deep_cave_turns + 1
                    if self.deep_cave_turns >= self.DWARF_WAKE_THRESHOLD:
                        self.dwarves_auto_woken = true
                        self.wake_dwarves()
                # Pirate observes treasure carry-count; activates
                # at threshold, then has a per-turn chance to
                # steal. The driver checks pirate_try_steal()
                # results and applies the consequence.
                self.pirate.treasures_carried(self.player.inventory_size())
                # Stalking dwarves in the player's room get a
                # per-turn axe-throw chance. We resolve the
                # first-encountered stalking dwarf — a single
                # death is a single death whether one dwarf or
                # five threw the axe. Adventure surfaces the
                # message via dwarf_threw_axe().
                self._maybe_dwarf_attack(r)
                # Track first-visit for the visit_score
                # component. CCA-canonical: each unique room
                # explored is worth one point.
                if not self.rooms_visited.has(r):
                    self.rooms_visited.append(r)
                    self.score_visits = self.score_visits + 1
                    self.real_score = self.real_score + 1
                self.turns = self.turns + 1
            }

            light_lamp()      { self.lamp.light() }
            extinguish_lamp() { self.lamp.extinguish() }
            refresh_lamp()    { self.lamp.refresh() }

            get_lamp_state(): String          { @@:(self.lamp.get_state()) }
            get_lamp_message(): String        { @@:(self.lamp.last_message()) }
            is_lit(): bool                    { @@:(self.lamp.is_lit()) }
            battery_left(): int               { @@:(self.lamp.battery_left()) }
            turn_count(): int                 { @@:(self.turns) }
            player_room(): int                { @@:(self.player.get_room()) }
            player_state(): String            { @@:(self.player.get_state()) }
            room_is_dark_now(): bool          { @@:(self._room_is_dark(self.player.get_room())) }
            darkness_consumed_count(): int    { @@:(self.darkness.consumed_count) }
            backpack_blocked_count(): int     { @@:(self.backpack.consumed_count) }
            magic_transforms_count(): int     { @@:(self.magic.transforms_count) }
            score(): int                      { @@:(self.real_score) }
            treasure_score(): int             { @@:(self.score_treasures) }
            visit_score(): int                { @@:(self.score_visits) }
            hint_penalty(): int               { @@:(self.score_hints) }
            endgame_score(): int              { @@:(self.score_endgame) }
            commands_seen(): int              { @@:(self.score_ledger.commands_seen()) }
            bird_state(): String              { @@:(self.bird.get_state()) }
            bird_location(): int              { @@:(self.bird.get_location()) }
            snake_state(): String             { @@:(self.snake.get_state()) }
            bear_state(): String              { @@:(self.bear.get_state()) }
            bear_dangerous(): bool            { @@:(self.bear.is_dangerous()) }
            troll_state(): String             { @@:(self.troll.get_state()) }
            troll_blocking(): bool            { @@:(self.troll.is_blocking_bridge()) }

            troll_bridge_collapsed(): bool    { @@:(self.troll_bridge_down) }
            collapse_troll_bridge() {
                self.troll_bridge_down = true
            }

            wake_dwarves() {
                # Spread the five dwarves across the cave's
                # transit and combat rooms. Real CCA wakes
                # them probabilistically as the player wanders;
                # this is the deterministic version for testing.
                self.dwarf1.wake_up(12)   # awkward canyon
                self.dwarf2.wake_up(33)   # Y2 marker
                self.dwarf3.wake_up(47)   # snake passage
                self.dwarf4.wake_up(65)   # bedquilt / bear chamber (canon 65)
                self.dwarf5.wake_up(118)  # cliff with ledge (beyond bridge)
            }

            bump_dwarf_anger() {
                # FEED dwarf in canon (advent.for STMT 9213) raises
                # DFLAG by one, ramping the knife-throw hit pct via
                # `95*(DFLAG-2)/1000`. Each FEED makes them angrier;
                # there's no upper cap in canon (DFLAG can climb to
                # 20 for save-game branch, etc.) so we just add 1.
                self.dwarf_anger = self.dwarf_anger + 1
            }
            get_dwarf_anger(): int { @@:(self.dwarf_anger) }

            attack_dwarf_in_room(): String {
                var r: int = self.player.get_room()
                # The if-ladder version of "find the right
                # parameterized instance." 5 branches; small
                # enough that the lack of array iteration
                # doesn't hurt. Same shape as the bus's
                # _dispatch_to.
                # On a kill, canon CCA leaves the dwarf's "rod
                # with a mark" lying at the player's room — same
                # rule for every dwarf; do it once per kill.
                if self.dwarf1.get_state() == "stalking" and self.dwarf1.get_room() == r:
                    self.dwarf1.attack()
                    if self.dwarf1.get_state() == "dead":
                        self.mark_rod_item.place(r)
                        @@:return("You killed dwarf 1.")
                    @@:return("Your axe missed dwarf 1.")
                elif self.dwarf2.get_state() == "stalking" and self.dwarf2.get_room() == r:
                    self.dwarf2.attack()
                    if self.dwarf2.get_state() == "dead":
                        self.mark_rod_item.place(r)
                        @@:return("You killed dwarf 2.")
                    @@:return("Your axe missed dwarf 2.")
                elif self.dwarf3.get_state() == "stalking" and self.dwarf3.get_room() == r:
                    self.dwarf3.attack()
                    if self.dwarf3.get_state() == "dead":
                        self.mark_rod_item.place(r)
                        @@:return("You killed dwarf 3.")
                    @@:return("Your axe missed dwarf 3.")
                elif self.dwarf4.get_state() == "stalking" and self.dwarf4.get_room() == r:
                    self.dwarf4.attack()
                    if self.dwarf4.get_state() == "dead":
                        self.mark_rod_item.place(r)
                        @@:return("You killed dwarf 4.")
                    @@:return("Your axe missed dwarf 4.")
                elif self.dwarf5.get_state() == "stalking" and self.dwarf5.get_room() == r:
                    self.dwarf5.attack()
                    if self.dwarf5.get_state() == "dead":
                        self.mark_rod_item.place(r)
                        @@:return("You killed dwarf 5.")
                    @@:return("Your axe missed dwarf 5.")
                @@:("There's no dwarf here.")
            }

            living_dwarves(): int {
                var n: int = 0
                if self.dwarf1.get_state() != "dead":
                    n = n + 1
                if self.dwarf2.get_state() != "dead":
                    n = n + 1
                if self.dwarf3.get_state() != "dead":
                    n = n + 1
                if self.dwarf4.get_state() != "dead":
                    n = n + 1
                if self.dwarf5.get_state() != "dead":
                    n = n + 1
                @@:(n)
            }

            dwarf_threw_axe(): bool {
                # Latched flag — driver reads and clears via
                # the side-effect-free read pattern below.
                # Persistence-clean because it's a domain
                # bool, not a transient.
                var v: bool = self.dwarf_axe_flag
                self.dwarf_axe_flag = false
                @@:(v)
            }

            deposit_treasure() {
                self.endgame.treasure_deposited()
            }
            detonate_marker() {
                # Award the endgame bonus the moment the
                # detonation happens (i.e., the player solved
                # the repository puzzle). The endgame FSM
                # transitions to $Won; we mirror that as a +50
                # bump in the score breakdown.
                if self.endgame.in_repository() and not self.endgame.is_won():
                    self.score_endgame = self.score_endgame + 50
                    self.real_score = self.real_score + 50
                self.endgame.detonate()
            }
            # Canon BLAST outcomes (see interface comment above).
            # Each adds the canon score bonus and detonates the
            # endgame. Guarded on $InRepository so only post-
            # closing fires bonus + transition; pre-closing the
            # methods are harmless no-ops.
            blast_mastery() {
                if self.endgame.in_repository() and not self.endgame.is_won():
                    self.score_endgame = self.score_endgame + 45
                    self.real_score = self.real_score + 45
                    self.endgame.detonate()
            }
            blast_wrong_way() {
                if self.endgame.in_repository() and not self.endgame.is_won():
                    self.score_endgame = self.score_endgame + 30
                    self.real_score = self.real_score + 30
                    self.endgame.detonate()
            }
            blast_klutz() {
                if self.endgame.in_repository() and not self.endgame.is_won():
                    self.score_endgame = self.score_endgame + 25
                    self.real_score = self.real_score + 25
                    self.endgame.detonate()
            }
            endgame_state(): String   { @@:(self.endgame.get_state()) }
            endgame_closing(): bool   { @@:(self.endgame.is_closing()) }
            endgame_won(): bool       { @@:(self.endgame.is_won()) }
            endgame_timer(): float    { @@:(self.endgame.closing_timer()) }
            endgame_panic()           { self.endgame.panic() }
            endgame_panicked(): bool  { @@:(self.endgame.is_panicked()) }

            request_hint(name: String): String {
                # Each hint has different text. The Hint system
                # itself doesn't know what its hint says —
                # Adventure provides the message at request
                # time. Detect was-eligible-now-offered by
                # comparing state pre/post call; if a hint was
                # actually delivered, charge the canonical -2
                # score penalty.
                var was_eligible: bool = false
                if name == "bird":
                    was_eligible = self.bird_hint.is_eligible()
                elif name == "cave":
                    was_eligible = self.cave_hint.is_eligible()
                elif name == "snake":
                    was_eligible = self.snake_hint.is_eligible()
                elif name == "maze":
                    was_eligible = self.maze_hint.is_eligible()
                elif name == "plover":
                    was_eligible = self.plover_hint.is_eligible()
                elif name == "witts":
                    was_eligible = self.witts_hint.is_eligible()
                var response: String = "No hint by that name."
                if name == "bird":
                    # Canon msg #19 verbatim.
                    response = self.bird_hint.request_hint(
                        "The bird is frightened right now and you cannot catch it no matter what you try. Perhaps you might try later.")
                elif name == "cave":
                    # Canon msg #63 verbatim — cave-entry hint.
                    response = self.cave_hint.request_hint(
                        "The grate is very solid and has a hardened steel lock. You cannot enter without a key, and there are no keys nearby. I would recommend looking elsewhere for the keys.")
                elif name == "snake":
                    # Canon msg #21 verbatim.
                    response = self.snake_hint.request_hint(
                        "You can't kill the snake, or drive it away, or avoid it, or anything like that. There is a way to get by, but you don't have the necessary resources right now.")
                elif name == "maze":
                    # Canon hint #177 verbatim.
                    response = self.maze_hint.request_hint(
                        "You can make the passages look less alike by dropping things.")
                elif name == "plover":
                    # Canon hint #179 verbatim.
                    response = self.plover_hint.request_hint(
                        "There is a way to explore that region without having to worry about falling into a pit. None of the objects available is immediately useful in discovering the secret.")
                elif name == "witts":
                    # Canon hint #181 verbatim.
                    response = self.witts_hint.request_hint(
                        "Don't go west.")
                if was_eligible:
                    self.score_hints = self.score_hints - 2
                    self.real_score = self.real_score - 2
                @@:(response)
            }

            hint_state(name: String): String {
                if name == "bird":
                    @@:return(self.bird_hint.get_state())
                elif name == "cave":
                    @@:return(self.cave_hint.get_state())
                elif name == "snake":
                    @@:return(self.snake_hint.get_state())
                elif name == "maze":
                    @@:return(self.maze_hint.get_state())
                elif name == "plover":
                    @@:return(self.plover_hint.get_state())
                elif name == "witts":
                    @@:return(self.witts_hint.get_state())
                @@:("unknown")
            }

            dragon_state(): String  { @@:(self.dragon.get_state()) }
            dragon_alive(): bool    { @@:(self.dragon.is_alive()) }
            pirate_state(): String  { @@:(self.pirate.get_state()) }
            pirate_try_steal(): bool { @@:(self.pirate.try_steal()) }

            # Cross-FSM: drive the pirate steal AND relocate the
            # stolen treasure to the chest room. Treasure IDs are
            # walked in a fixed order so the same save+seed gives
            # the same target on replay. The Pirate FSM only knows
            # whether a steal triggered; Adventure (which has the
            # treasure roster) decides which treasure and where it
            # ends up. Same orchestrator pattern as bird→snake and
            # bear→troll: each subsystem owns its slice, Adventure
            # brokers the cross-cuts.
            pirate_attempt_steal(): String {
                if not self.pirate.try_steal():
                    @@:return("")
                # Canon: the pirate's chest is itself dynamic —
                # it appears at the chest room on the first
                # successful steal. reappear is idempotent for
                # subsequent steals (already at CHEST_ROOM).
                self.chest.reappear(self.CHEST_ROOM)
                # Walk treasures in canonical order; first one in
                # inventory gets stashed.
                if self.player.carrying(self.GOLD_ID):
                    self.player.drop(self.GOLD_ID)
                    self.gold.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.SILVER_ID):
                    self.player.drop(self.SILVER_ID)
                    self.silver.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.DIAMONDS_ID):
                    self.player.drop(self.DIAMONDS_ID)
                    self.diamonds.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.JEWELRY_ID):
                    self.player.drop(self.JEWELRY_ID)
                    self.jewelry.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.PEARL_ID):
                    self.player.drop(self.PEARL_ID)
                    self.pearl.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.VASE_ID):
                    self.player.drop(self.VASE_ID)
                    self.vase.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.EGGS_ID):
                    self.player.drop(self.EGGS_ID)
                    self.eggs.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.TRIDENT_ID):
                    self.player.drop(self.TRIDENT_ID)
                    self.trident.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.EMERALD_ID):
                    self.player.drop(self.EMERALD_ID)
                    self.emerald.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.SPICES_ID):
                    self.player.drop(self.SPICES_ID)
                    self.spices.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.PYRAMID_ID):
                    self.player.drop(self.PYRAMID_ID)
                    self.pyramid.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.RUG_ID):
                    self.player.drop(self.RUG_ID)
                    self.rug.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                if self.player.carrying(self.COINS_ID):
                    self.player.drop(self.COINS_ID)
                    self.coins.reappear(self.CHEST_ROOM)
                    @@:return("Out from the shadows behind you pounces a bearded pirate! \"Har, har,\" he chortles, \"I'll just take all this booty and hide it away with me chest deep in the maze!\" He snatches your treasure and vanishes into the gloom.")
                # Pirate rolled a steal but the player wasn't
                # carrying anything stash-able. The roll is
                # consumed (Pirate is now $Vanished); we just
                # surface a flavor message.
                @@:("A bearded pirate steps out of the gloom, sees your empty hands, and slinks off in disgust.")
            }

            bridge_built(): bool       { @@:(self.crystal_bridge.is_built()) }
            rod_in_inventory(): bool   { @@:(self.rod_item.is_carried()) }
            mark_rod_here(): bool      { @@:(self.mark_rod_item.is_carried() or self.mark_rod_item.is_in_room(self.player.get_room())) }
            grate_locked(): bool       { @@:(self.grate.is_locked()) }
            rusty_door_oiled(): bool   { @@:(not self.rusty_door.is_rusty()) }
            keys_in_inventory(): bool  { @@:(self.keys_item.is_carried()) }
            vending_loaded(): bool     { @@:(self.vending.is_loaded()) }
            plant_is_tall(): bool      { @@:(self.plant.is_tall()) }
            plant_is_huge(): bool      { @@:(self.plant.is_huge()) }
            bottle_in_inventory(): bool { @@:(self.bottle_item.is_carried()) }
            bottle_has_water(): bool   { @@:(self.bottle.has_water()) }

            plover_squeeze_blocked(): bool {
                # Canon: through the tight tunnel between the
                # alcove (99) and Plover Room (100) a player can
                # carry only the emerald (or nothing). Anything
                # else won't fit. We treat any non-emerald
                # inventory entry as a block.
                var size: int = self.player.inventory_size()
                if size == 0:
                    @@:return(false)
                if size == 1 and self.player.carrying(self.EMERALD_ID):
                    @@:return(false)
                @@:(true)
            }

            treasures_deposited(): int {
                var n: int = 0
                if self.gold.is_deposited():      n = n + 1
                if self.silver.is_deposited():    n = n + 1
                if self.diamonds.is_deposited():  n = n + 1
                if self.jewelry.is_deposited():   n = n + 1
                if self.pearl.is_deposited():     n = n + 1
                if self.vase.is_deposited():      n = n + 1
                if self.eggs.is_deposited():      n = n + 1
                if self.trident.is_deposited():   n = n + 1
                if self.emerald.is_deposited():   n = n + 1
                if self.spices.is_deposited():    n = n + 1
                if self.chest.is_deposited():     n = n + 1
                if self.pyramid.is_deposited():   n = n + 1
                if self.rug.is_deposited():       n = n + 1
                if self.coins.is_deposited():     n = n + 1
                if self.chain.is_deposited():     n = n + 1
                @@:(n)
            }

            total_score(): int {
                var s: int = 0
                if self.gold.is_deposited():      s = s + self.gold.get_value()
                if self.silver.is_deposited():    s = s + self.silver.get_value()
                if self.diamonds.is_deposited():  s = s + self.diamonds.get_value()
                if self.jewelry.is_deposited():   s = s + self.jewelry.get_value()
                if self.pearl.is_deposited():     s = s + self.pearl.get_value()
                if self.vase.is_deposited():      s = s + self.vase.get_value()
                if self.eggs.is_deposited():      s = s + self.eggs.get_value()
                if self.trident.is_deposited():   s = s + self.trident.get_value()
                if self.emerald.is_deposited():   s = s + self.emerald.get_value()
                if self.spices.is_deposited():    s = s + self.spices.get_value()
                if self.chest.is_deposited():     s = s + self.chest.get_value()
                if self.pyramid.is_deposited():   s = s + self.pyramid.get_value()
                if self.rug.is_deposited():       s = s + self.rug.get_value()
                if self.coins.is_deposited():     s = s + self.coins.get_value()
                if self.chain.is_deposited():     s = s + self.chain.get_value()
                @@:(s)
            }
        }

    actions:

        _maybe_dwarf_attack(room: int) {
            # Ask each dwarf in the player's room for an axe-
            # throw roll. First hit ends the turn. The dwarf
            # axe flag is set so the driver can render the
            # message; the player dies via player.die() which
            # routes through the standard $Alive → $Dead path.
            # Canon: every throw — hit or miss — leaves the axe
            # in the room. The Item FSM's `place(at_room)` event
            # handles "appear in world at this room" cleanly
            # whether the axe was already there ($InRoom) or
            # never existed yet ($InRoom with location -1).
            if self.dwarf1.get_state() == "stalking" and self.dwarf1.get_room() == room:
                var d1_hit: bool = self.dwarf1.try_throw_axe(self.dwarf_anger)
                self.axe_item.place(room)
                if d1_hit:
                    self.dwarf_axe_flag = true
                    self.player.die()
                    return
            if self.dwarf2.get_state() == "stalking" and self.dwarf2.get_room() == room:
                var d2_hit: bool = self.dwarf2.try_throw_axe(self.dwarf_anger)
                self.axe_item.place(room)
                if d2_hit:
                    self.dwarf_axe_flag = true
                    self.player.die()
                    return
            if self.dwarf3.get_state() == "stalking" and self.dwarf3.get_room() == room:
                var d3_hit: bool = self.dwarf3.try_throw_axe(self.dwarf_anger)
                self.axe_item.place(room)
                if d3_hit:
                    self.dwarf_axe_flag = true
                    self.player.die()
                    return
            if self.dwarf4.get_state() == "stalking" and self.dwarf4.get_room() == room:
                var d4_hit: bool = self.dwarf4.try_throw_axe(self.dwarf_anger)
                self.axe_item.place(room)
                if d4_hit:
                    self.dwarf_axe_flag = true
                    self.player.die()
                    return
            if self.dwarf5.get_state() == "stalking" and self.dwarf5.get_room() == room:
                var d5_hit: bool = self.dwarf5.try_throw_axe(self.dwarf_anger)
                self.axe_item.place(room)
                if d5_hit:
                    self.dwarf_axe_flag = true
                    self.player.die()
                    return
        }

        # The bus holds names; this routes them to the actual
        # @@system field. Add a branch per aspect as we grow.
        # The ordering here doesn't matter — the bus already
        # walked listeners in priority order.
        _dispatch_to(name: String, event: Dictionary): Dictionary {
            if name == "darkness":
                return self.darkness.try_handle(event)
            elif name == "backpack":
                return self.backpack.try_handle(event)
            elif name == "magic":
                return self.magic.try_handle(event)
            elif name == "score":
                return self.score_ledger.try_handle(event)
            return {"verdict": "pass", "event": event}
        }

        # Base verb dispatch. Stub today — only knows a handful
        # of verbs. The real CCA verb table is ~40 entries. As
        # rooms and items land, this branches further.
        _base_handle(event: Dictionary): String {
            var verb: String = event.verb
            var noun: String = event.noun
            if verb == "look":
                return self._verb_look()
            elif verb == "light":
                self.lamp.light()
                if self.lamp.get_state() == "out":
                    # Canon msg #184 derivative — lamp won't relight if dead.
                    return "Your lamp has run out of power."
                # Canon msg #39 verbatim.
                return "Your lamp is now on."
            elif verb == "extinguish":
                self.lamp.extinguish()
                # Canon msg #40 verbatim.
                return "Your lamp is now off."
            elif verb == "move":
                return self._verb_move(noun)
            elif verb == "take":
                # BackpackLimit has already gated full-inventory.
                return self._verb_take(noun)
            elif verb == "drop":
                return self._verb_drop(noun)
            elif verb == "release":
                return self._verb_release(noun)
            elif verb == "feed":
                return self._verb_feed(noun)
            elif verb == "attack":
                return self._verb_attack(noun)
            elif verb == "yes":
                return self._verb_yes()
            elif verb == "no":
                return self._verb_no()
            elif verb == "examine":
                return self._verb_examine(noun)
            elif verb == "read":
                return self._verb_read(noun)
            elif verb == "throw":
                return self._verb_throw(noun)
            elif verb == "wave":
                return self._verb_wave(noun)
            elif verb == "unlock" or verb == "open":
                # Canon: OPEN CLAM is the puzzle action — clam
                # is not a lock but a shellfish to be cracked.
                if noun == "clam" or noun == "oyster":
                    return self._verb_break(noun)
                return self._verb_unlock(noun)
            elif verb == "break":
                return self._verb_break(noun)
            elif verb == "lock":
                return self._verb_lock(noun)
            elif verb == "insert" or verb == "use":
                return self._verb_insert(noun)
            elif verb == "fill":
                return self._verb_fill(noun)
            elif verb == "pour":
                return self._verb_pour(noun)
            elif verb == "water":
                return self._verb_water(noun)
            elif verb == "drink":
                return self._verb_drink(noun)
            elif verb == "eat":
                return self._verb_eat(noun)
            elif verb == "fee" or verb == "fie" or verb == "foe" or verb == "foo":
                return self._verb_chant(verb)
            elif verb == "xyzzy" or verb == "plugh" or verb == "plover":
                # MagicWordTeleport didn't transform — wrong room.
                # Canon msg #50.
                return "Good try, but that is an old worn-out magic word."
            elif verb == "stop":
                # Canon msg #139.
                return "I don't know the word \"stop\". Use \"quit\" if you want to give up."
            elif verb == "dig":
                # Canon msg #66.
                return "Digging without a shovel is quite impractical. Even with a shovel progress is unlikely."
            elif verb == "noop":
                return ""
            # Sentinel string the driver intercepts and substitutes
            # with canon msg #13/#60/#61 in the canonical 20/64/16
            # distribution (advent.for STMT 3000).
            return "I don't know how to '" + verb + "'."
        }

        _verb_look(): String {
            # Per-room descriptions. Real CCA reads from a data
            # table; we keep them in code so the @@[persist]
            # round-trip and the chapter prose can co-exist
            # without an extra resource layer.
            var r: int = self.player.get_room()
            var base: String = "You are deep in the cave."
            # --- Canonical CCA rooms (Crowther+Woods 1977 numbering) ---
            # Surface block (1-9): the road, hill, well house, valley,
            # forests, slit in the streambed, depression with grate,
            # and the chamber below the grate. The grate itself is
            # described but not gated — adding the keys-and-grate
            # puzzle would mean another full FSM, and we already
            # demonstrate the locked-door pattern with CrystalBridge.
            if r == 1:
                base = "YOU ARE STANDING AT THE END OF A ROAD BEFORE A SMALL BRICK BUILDING. AROUND YOU IS A FOREST.  A SMALL STREAM FLOWS OUT OF THE BUILDING AND DOWN A GULLY."
            elif r == 2:
                base = "YOU HAVE WALKED UP A HILL, STILL IN THE FOREST.  THE ROAD SLOPES BACK DOWN THE OTHER SIDE OF THE HILL.  THERE IS A BUILDING IN THE DISTANCE."
            elif r == 3:
                base = "YOU ARE INSIDE A BUILDING, A WELL HOUSE FOR A LARGE SPRING."
            elif r == 4:
                base = "YOU ARE IN A VALLEY IN THE FOREST BESIDE A STREAM TUMBLING ALONG A ROCKY BED."
            elif r == 5:
                base = "YOU ARE IN OPEN FOREST, WITH A DEEP VALLEY TO ONE SIDE."
            elif r == 6:
                base = "YOU ARE IN OPEN FOREST NEAR BOTH A VALLEY AND A ROAD."
            elif r == 7:
                base = "AT YOUR FEET ALL THE WATER OF THE STREAM SPLASHES INTO A 2-INCH SLIT IN THE ROCK.  DOWNSTREAM THE STREAMBED IS BARE ROCK."
            elif r == 8:
                base = "YOU ARE IN A 20-FOOT DEPRESSION FLOORED WITH BARE DIRT.  SET INTO THE DIRT IS A STRONG STEEL GRATE MOUNTED IN CONCRETE.  A DRY STREAMBED LEADS INTO THE DEPRESSION."
            elif r == 9:
                base = "YOU ARE IN A SMALL CHAMBER BENEATH A 3X3 STEEL GRATE TO THE SURFACE. A LOW CRAWL OVER COBBLES LEADS INWARD TO THE WEST."
            elif r == 11:
                base = "YOU ARE IN A DEBRIS ROOM FILLED WITH STUFF WASHED IN FROM THE SURFACE. A LOW WIDE PASSAGE WITH COBBLES BECOMES PLUGGED WITH MUD AND DEBRIS HERE, BUT AN AWKWARD CANYON LEADS UPWARD AND WEST.  A NOTE ON THE WALL SAYS \"MAGIC WORD XYZZY\"."
            elif r == 12:
                base = "YOU ARE IN AN AWKWARD SLOPING EAST/WEST CANYON."
            elif r == 33:
                base = "YOU ARE IN A LARGE ROOM, WITH A PASSAGE TO THE SOUTH, A PASSAGE TO THE WEST, AND A WALL OF BROKEN ROCK TO THE EAST.  THERE IS A LARGE \"Y2\" ON A ROCK IN THE ROOM'S CENTER."
            elif r == 13:
                base = "YOU ARE IN A SPLENDID CHAMBER THIRTY FEET HIGH.  THE WALLS ARE FROZEN RIVERS OF ORANGE STONE.  AN AWKWARD CANYON AND A GOOD PASSAGE EXIT FROM EAST AND WEST SIDES OF THE CHAMBER."
            elif r == 100:
                base = "YOU'RE IN A SMALL CHAMBER LIT BY AN EERIE GREEN LIGHT.  AN EXTREMELY NARROW TUNNEL EXITS TO THE WEST.  A DARK CORRIDOR LEADS NE."
            elif r == 47:
                base = "DEAD END"
            elif r == 71:
                base = "YOU ARE IN A SECRET CANYON AT A JUNCTION OF THREE CANYONS, BEARING NORTH, SOUTH, AND SE.  THE NORTH ONE IS AS TALL AS THE OTHER TWO COMBINED."
            elif r == 65:
                base = "YOU ARE IN BEDQUILT, A LONG EAST/WEST PASSAGE WITH HOLES EVERYWHERE. TO EXPLORE AT RANDOM SELECT NORTH, SOUTH, UP, OR DOWN."
            elif r == 130:
                base = "YOU ARE INSIDE A BARREN ROOM.  THE CENTER OF THE ROOM IS COMPLETELY EMPTY EXCEPT FOR SOME DUST.  MARKS IN THE DUST LEAD AWAY TOWARD THE FAR END OF THE ROOM.  THE ONLY EXIT IS THE WAY YOU CAME IN."
            elif r == 103:
                base = "YOU'RE IN A LARGE ROOM CARVED OUT OF SEDIMENTARY ROCK.  THE FLOOR AND WALLS ARE LITTERED WITH BITS OF SHELLS IMBEDDED IN THE STONE.  A SHALLOW PASSAGE PROCEEDS DOWNWARD, AND A SOMEWHAT STEEPER ONE LEADS UP.  A LOW HANDS AND KNEES PASSAGE ENTERS FROM THE SOUTH."
            elif r == 117:
                base = "YOU ARE ON ONE SIDE OF A LARGE, DEEP CHASM.  A HEAVY WHITE MIST RISING UP FROM BELOW OBSCURES ALL VIEW OF THE FAR SIDE.  A SW PATH LEADS AWAY FROM THE CHASM INTO A WINDING CORRIDOR."
            elif r == 118:
                base = "YOU ARE IN A LONG WINDING CORRIDOR SLOPING OUT OF SIGHT IN BOTH DIRECTIONS."
            elif r == 10:
                base = "YOU ARE CRAWLING OVER COBBLES IN A LOW PASSAGE.  THERE IS A DIM LIGHT AT THE EAST END OF THE PASSAGE."
            elif r == 120:
                base = "YOU ARE IN A SECRET CANYON WHICH EXITS TO THE NORTH AND EAST."
            elif r == 97:
