#!/usr/bin/env bash
# ============================================================
# pre-commit — parse-check + drift detector + (conditional) tests
# ============================================================
# Install: ln -s "$(pwd)/cca/scripts/pre-commit" .git/hooks/pre-commit
#
# What it catches:
#   1. GDScript parse errors that would only fire at runtime
#      (the bug class that shipped _SAVE_MAGIC as a const +
#      crashed every test that did `extends Driver`).
#   2. CCA driver drift between cca/godot/scripts/driver.gd and
#      arcade/godot/scripts/cca_main.gd. New unexpected divergent
#      functions or unauthorized arcade-only methods.
#   3. CCA test regressions on changes that can actually cause
#      one — Frame source, driver, helpers, or test files (V1.2).
#
# Skip with `git commit --no-verify` if needed, or set
# PRE_COMMIT_SKIP_TESTS=1 to skip just the test-suite step.
# ============================================================
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

FAILED=0

# ---------- Parse-check changed .gd files ----------
CHANGED_GD=$(git diff --cached --name-only --diff-filter=AM | grep -E '\.gd$' || true)

if [ -n "$CHANGED_GD" ]; then
    if ! command -v godot >/dev/null 2>&1; then
        echo "pre-commit: godot not on PATH — skipping parse check"
    else
        echo "pre-commit: parse-checking $(echo "$CHANGED_GD" | wc -l | tr -d ' ') changed .gd file(s)..."
        for f in $CHANGED_GD; do
            # Pick the godot project rooted nearest the file.
            project_dir=""
            d="$(dirname "$f")"
            while [ "$d" != "/" ] && [ "$d" != "." ]; do
                if [ -f "$d/project.godot" ]; then
                    project_dir="$d"
                    break
                fi
                d="$(dirname "$d")"
            done
            if [ -z "$project_dir" ]; then
                continue   # script not under any godot project (e.g. tools/)
            fi
            rel="${f#$project_dir/}"
            out=$(godot --headless --check-only --path "$project_dir" --script "$rel" 2>&1 | grep -E "(SCRIPT ERROR|Parse Error)" || true)
            # Filter known false positives — Arcade autoload, etc. — these only resolve at full project boot.
            real_errors=$(echo "$out" | grep -vE "Identifier not found: (Arcade|ExitDialogScript)" || true)
            if [ -n "$real_errors" ]; then
                echo "  FAIL: $f"
                echo "$real_errors" | sed 's/^/    /'
                FAILED=1
            fi
        done
    fi
fi

# ---------- CCA driver drift check ----------
# Always run — drift can come from rebuilds the user didn't commit.
if [ -x "$REPO_ROOT/cca/scripts/check_cca_drift.py" ]; then
    if ! python3 "$REPO_ROOT/cca/scripts/check_cca_drift.py" > /tmp/_drift_check.log 2>&1; then
        echo
        echo "pre-commit: CCA driver drift check FAILED"
        cat /tmp/_drift_check.log | sed 's/^/  /'
        FAILED=1
    fi
fi

# ---------- CCA test suite (conditional) ----------
# Only run on changes that can actually break tests — Frame source,
# the standalone driver, the arcade driver mirror, test helpers,
# or test files themselves. Skips for docs-only / build-script /
# config commits. ~3 min when it runs.
if [ -z "${PRE_COMMIT_SKIP_TESTS:-}" ]; then
    CHANGED_TEST_TRIGGER=$(git diff --cached --name-only --diff-filter=AM | grep -E '^(cca/frame/|cca/godot/scripts/(driver|cca|aspects|_test_helpers|topology)\.gd|cca/tests/|arcade/godot/scripts/cca_main\.gd|arcade/tests/)' || true)
    if [ -n "$CHANGED_TEST_TRIGGER" ]; then
        if ! command -v godot >/dev/null 2>&1; then
            echo "pre-commit: godot not on PATH — skipping test suite"
        elif [ ! -x "$REPO_ROOT/cca/run_tests.sh" ]; then
            echo "pre-commit: cca/run_tests.sh not executable — skipping test suite"
        else
            echo "pre-commit: running CCA test suite --fast (changes touch frame/driver/tests)..."
            # --fast skips the long-running BFS state-space tests
            # (~15 min) so the hook stays under ~3 min. CCA_SMOKE
            # additionally drops audit caps so the still-included
            # gap/union audits run in ~40s each. Full coverage
            # runs on demand (./run_tests.sh, no env var) and in
            # CI. Both modes exercise every code path; the slow
            # set just trades runtime for coverage depth.
            if ! (cd "$REPO_ROOT/cca" && CCA_SMOKE=1 ./run_tests.sh --fast > /tmp/_cca_tests.log 2>&1); then
                echo
                echo "pre-commit: CCA test suite FAILED"
                tail -30 /tmp/_cca_tests.log | sed 's/^/  /'
                echo
                echo "  (full log at /tmp/_cca_tests.log)"
                FAILED=1
            else
                # Echo just the summary line so the commit author
                # sees the green count.
                tail -3 /tmp/_cca_tests.log | sed 's/^/  /'
            fi
        fi
    fi
fi

if [ "$FAILED" -ne 0 ]; then
    echo
    echo "pre-commit: $FAILED issue(s). Fix or override with --no-verify."
    exit 1
fi

exit 0
