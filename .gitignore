# macOS
.DS_Store

# Godot
.godot/
*.import
*.uid
# Godot 4.x emits a 20-byte `<file>.uid` next to every imported
# script — opaque resource-identifier cache regenerated on
# every editor open / build.sh run. Excluded as a wildcard so
# the noise doesn't crowd `git status` for test files and
# hand-written scripts (the generated-script .uid pairs were
# implicitly covered before the lifecycle test files were
# added in V1.2 Tier 1b).
export_presets.cfg
# …except the arcade cabinet's preset, which is the build
# config for the itch.io distribution and should be committed.
!arcade/godot/export_presets.cfg

# Python bytecode (canon/audit_string_join.py + helpers)
__pycache__/
*.pyc

# framec output — regenerated by build.sh
arcade/generated/
ch??-*/generated/
cca/generated/

# generated game scripts (mixed with hand-written drivers in same dirs, so listed explicitly)
arcade/godot/scripts/aspects.gd
arcade/godot/scripts/asteroids.gd
arcade/godot/scripts/breakout.gd
arcade/godot/scripts/cca.gd
arcade/godot/scripts/dialog.gd
arcade/godot/scripts/invaders.gd
arcade/godot/scripts/pacman.gd
arcade/godot/scripts/platformer.gd
arcade/godot/scripts/pong.gd
arcade/godot/scripts/scoreboard.gd
arcade/godot/scripts/shooter.gd
arcade/godot/scripts/stealth.gd
ch01-pong/godot/scripts/pong.gd
ch02-breakout/godot/scripts/breakout.gd
ch03-invaders/godot/scripts/invaders.gd
ch04-asteroids/godot/scripts/asteroids.gd
ch05-pacman/godot/scripts/pacman.gd
ch06-platformer/godot/scripts/platformer.gd
ch07-shooter/godot/scripts/shooter.gd
ch08-stealth/godot/scripts/stealth.gd
cca/godot/scripts/aspects.gd
cca/godot/scripts/cca.gd

# end-user packaging — published on itch.io, not in repo
arcade/Run Arcade.app/
arcade/dist/
